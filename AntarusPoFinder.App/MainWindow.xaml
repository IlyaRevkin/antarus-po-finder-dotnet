<Window x:Class="AntarusPoFinder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AntarusPoFinder.App.ViewModels"
        Title="Antarus ПО Finder" MinWidth="1100" MinHeight="720" Width="1280" Height="800"
        Icon="/Assets/icon.ico" AllowDrop="False" Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Update banner -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                Visibility="{Binding UpdateBannerVisible, Converter={StaticResource BoolToVis}}">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding UpdateBannerText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Обновить сейчас" Margin="12,0,8,0"
                        IsEnabled="{Binding UpdateActionEnabled}"
                        Command="{Binding InstallUpdateCommand}"/>
                <Button Grid.Column="2" Content="Позже" Style="{StaticResource SecondaryButton}"
                        IsEnabled="{Binding UpdateActionEnabled}"
                        Command="{Binding DismissUpdateBannerCommand}"/>
            </Grid>
        </Border>

        <!-- Firmware update banner -->
        <Border Grid.Row="1" Background="{DynamicResource AccentBrush}"
                Visibility="{Binding FwUpdateBannerVisible, Converter={StaticResource BoolToVis}}">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FwUpdateBannerText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Обновить все" Margin="12,0,8,0"
                        Command="{Binding UpdateAllFwCommand}"/>
                <Button Grid.Column="2" Content="Подробно" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                        Command="{Binding ShowFwUpdatesDetailsCommand}"/>
                <Button Grid.Column="3" Content="Скрыть" Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissFwUpdateBannerCommand}"/>
            </Grid>
        </Border>

        <!-- Unknown files/folders banner (Task 3 — see HierarchyService.ScanUnknownFiles) -->
        <Border Grid.Row="2" Background="{DynamicResource AccentBrush}"
                Visibility="{Binding UnknownItemsBannerVisible, Converter={StaticResource BoolToVis}}">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding UnknownItemsBannerText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Показать" Margin="12,0,8,0"
                        Command="{Binding ShowUnknownItemsDetailsCommand}"/>
                <Button Grid.Column="2" Content="Скрыть" Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissUnknownItemsBannerCommand}"/>
            </Grid>
        </Border>

        <!-- Hierarchy sync conflicts banner (Задача 1 — see Database.ClassifyHierarchyChange) -->
        <Border Grid.Row="3" Background="{DynamicResource AccentBrush}"
                Visibility="{Binding HierarchyConflictBannerVisible, Converter={StaticResource BoolToVis}}">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding HierarchyConflictBannerText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Показать и решить" Margin="12,0,8,0"
                        Command="{Binding ShowHierarchyConflictsDetailsCommand}"/>
                <Button Grid.Column="2" Content="Скрыть" Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissHierarchyConflictsBannerCommand}"/>
            </Grid>
        </Border>

        <!-- Плашка-накопитель изменений, готовых к отправке (Задача 4, отправитель) — неисчезающая
             по дизайну, пока накопитель не пуст: в отличие от остальных баннеров здесь нет
             автоскрытия по таймеру (см. MainWindowViewModel.RefreshPendingChangesBanner). -->
        <Border Grid.Row="4" Background="{DynamicResource AccentBrush}"
                Visibility="{Binding PendingChangesBannerVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding PendingChangesSummary}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Отправить всё" Margin="12,0,8,0"
                            Command="{Binding SendPendingChangesNowCommand}"/>
                    <Button Grid.Column="2" Content="Список" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Command="{Binding TogglePendingChangesDetailsCommand}"/>
                    <Button Grid.Column="3" Content="Скрыть" Style="{StaticResource SecondaryButton}"
                            Command="{Binding DismissPendingChangesBannerCommand}"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding PendingChangesDetails}" Margin="0,6,0,0"
                              Visibility="{Binding PendingChangesDetailsVisible, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource TextOnAccentBrush}" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Плашка «Поступили изменения» (Задача 4, приёмник) — информационная, аддитивные
             изменения/удаления к этому моменту уже применены (п.5 дизайна синхронизации, см.
             MainWindowViewModel.ShowIncomingChangesBanner); конфликты правки одного поля идут через
             отдельный баннер конфликтов выше, сюда не попадают. -->
        <Border Grid.Row="5" Background="{DynamicResource AccentBrush}"
                Visibility="{Binding IncomingChangesBannerVisible, Converter={StaticResource BoolToVis}}">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding IncomingChangesBannerText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Скрыть" Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissIncomingChangesBannerCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="215"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header band: logo/role (sidebar side) and the Быстрый доступ top bar (content side,
                 "top"/"top_labeled" mode only) share this ONE Grid row instead of each living inside
                 its own independently-sized container — their bottom borders previously landed at
                 different heights (the sidebar's logo+role block and the content column's quick-apps
                 bar were sized independently) and never lined up. A shared row's height is the max of
                 whichever cell is tallest, so both bottom edges always land on the exact same row
                 boundary, however tall either side's content is (e.g. "иконки с подписями" is taller
                 than plain icons). When the bar is hidden entirely ("sidebar" quick-apps mode, the
                 default) this row still reserves the sidebar header's own height — but the page
                 content Border below no longer waits for it: it spans into this row too, so it isn't
                 left dangling under an empty gap that has nothing of its own to justify (see that
                 Border's own comment near the bottom of this Grid). -->
            <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource BgSidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" Padding="12,16,12,12">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Ellipse Width="28" Height="28" Fill="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Antarus ПО Finder" FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding RoleLabel}" VerticalAlignment="Center" Style="{StaticResource MutedText}"/>
                        <Button x:Name="RoleSwitchNavButton" Style="{StaticResource IconButton}" Width="18" Height="18" Padding="0"
                                Margin="4,0,0,0" ToolTip="Сменить роль" Click="RoleSwitchButton_Click">
                            <TextBlock Text="&#8635;" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Panel.ZIndex="1" Background="{DynamicResource BgSidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1"
                    Visibility="{Binding QuickAppsTopVisible, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding QuickApps}" Margin="16,10" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0" Width="56">
                                <Button Style="{StaticResource QuickAppBubbleButton}" HorizontalAlignment="Center"
                                        Command="{Binding LaunchCommand}" ToolTip="{Binding Name}">
                                    <Image Source="{Binding IconSource}" Width="22" Height="22"
                                           Visibility="{Binding IconSource, Converter={StaticResource NullToVis}}"/>
                                </Button>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource MutedText}" FontSize="10"
                                           HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0" MaxWidth="56"
                                           Visibility="{Binding DataContext.QuickAppsTopShowLabels, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Sidebar (below the shared header band) -->
            <Border x:Name="SidebarBorder" Grid.Row="1" Grid.Column="0" Background="{DynamicResource BgSidebarBrush}">
                <DockPanel Margin="0,12,0,12" LastChildFill="True">

                    <!-- LastChildFill applies to whichever child is LAST in this collection, regardless
                         of its own Dock value — so bottom-docked buttons must come first (each takes
                         its natural height off the bottom, in declaration order from bottom to top)
                         and the scrollable content last (fills the rest). -->

                    <!-- Secondary/rare-use strip: Настройки, Сетевые диски, Тикеты, Смена роли, Обучение,
                         GitHub and the theme switch — all "check/use once in a while, not every visit"
                         (per the operator: these were crowding the sidebar at the same visual weight as
                         Поиск/Осмотр/Модерация тегов/Загрузка ПО/Параметры ПЧ/УПП, which ARE used
                         constantly). Purely a placement change — every item here has exactly the same
                         role access/visibility as before (RolesConfig.RoleAccess for the page items,
                         SettingsVisible for Настройки), nothing here changes WHO can use it, only where
                         its button lives. "Уведомления" deliberately stays OUTSIDE this block, full-size —
                         it carries an unread-count badge and wasn't named as something to compact.

                         Collapsed by default (MoreSectionToggle.IsChecked starts unset/false) — the whole
                         point was to stop this from being permanently visible clutter; clicking the
                         "› ДОПОЛНИТЕЛЬНО" header expands it downward, in place, standard accordion/
                         disclosure pattern. Not persisted across restarts — always starts collapsed. -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,0">
                        <Separator/>
                        <ToggleButton x:Name="MoreSectionToggle" Style="{StaticResource SidebarExpanderHeader}"/>
                        <StackPanel x:Name="MoreSectionContent"
                                    Visibility="{Binding IsChecked, ElementName=MoreSectionToggle, Converter={StaticResource BoolToVis}}" Margin="0,4,0,0">

                            <TextBlock Text="РАБОЧИЕ" Style="{StaticResource MutedText}" Margin="0,0,0,2" FontSize="9"/>
                            <Button x:Name="SettingsNavButton" Style="{StaticResource CompactNavButton}"
                                    Margin="0,0,0,2" HorizontalAlignment="Stretch"
                                    Visibility="{Binding SettingsVisible, Converter={StaticResource BoolToVis}}"
                                    Tag="{Binding IsSettingsActive, Converter={StaticResource ActiveTagConverter}}"
                                    Command="{Binding NavigateCommand}" CommandParameter="settings">
                                <!-- Same fix as the main nav list below: an explicit per-instance Style,
                                     not just the Button's own Foreground, since a plain TextBlock always
                                     wins over inheritance via the app-wide implicit TextBlock style. -->
                                <TextBlock Text="Настройки">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <ItemsControl x:Name="CompactNavItemsControl" ItemsSource="{Binding NavItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource CompactNavButton}"
                                                Margin="0,0,0,2" HorizontalAlignment="Stretch"
                                                Visibility="{Binding ShowInCompactList, Converter={StaticResource BoolToVis}}"
                                                Tag="{Binding IsActive, Converter={StaticResource ActiveTagConverter}}"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding PageId}">
                                            <TextBlock Text="{Binding Label}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="ЛИЧНОЕ" Style="{StaticResource MutedText}" Margin="0,6,0,2" FontSize="9"/>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding ThemeLabel}" VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}"/>
                                <ToggleButton x:Name="ThemeToggleControl" Grid.Column="1" Style="{StaticResource ThemeToggleSwitch}"
                                              IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"/>
                            </Grid>

                            <TextBlock Text="СПРАВКА" Style="{StaticResource MutedText}" Margin="0,6,0,2" FontSize="9"/>
                            <Button x:Name="OnboardingNavButton" Content="Обучение" Style="{StaticResource CompactNavButton}"
                                    Margin="0,0,0,2" HorizontalAlignment="Stretch" Click="ShowOnboarding_Click"/>
                            <TextBlock HorizontalAlignment="Center" Margin="0,4,0,2">
                                <Hyperlink NavigateUri="https://github.com/IlyaRevkin/antarus-po-finder-dotnet" RequestNavigate="GitHubLink_RequestNavigate">GitHub</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="NotificationsNavButton" DockPanel.Dock="Bottom" Style="{StaticResource SecondaryButton}"
                            Margin="12,4,12,0" Command="{Binding ShowNotificationHistoryCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Уведомления"/>
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                    Padding="6,0" MinWidth="16" Margin="6,0,0,0"
                                    Visibility="{Binding UnseenNotificationsCount, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="{Binding UnseenNotificationsCount}" FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextOnAccentBrush}"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Separator DockPanel.Dock="Bottom" Margin="0,8,0,0"/>

                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,0">
                            <ItemsControl x:Name="NavItemsControl" ItemsSource="{Binding NavItems}" Margin="8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource NavButton}"
                                                Margin="0,0,0,2" HorizontalAlignment="Stretch"
                                                Visibility="{Binding ShowInMainList, Converter={StaticResource BoolToVis}}"
                                                Tag="{Binding IsActive, Converter={StaticResource ActiveTagConverter}}"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding PageId}">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Explicit per-instance Style+DataTrigger, not just the Button's own
                                                     Foreground (set by NavButton's Tag="Active" trigger) — a plain
                                                     TextBlock always picks up the app-wide implicit TextBlock style
                                                     (Foreground=TextBrush), which has higher precedence than an
                                                     inherited Foreground value, so it silently overrode the Button's
                                                     active-state Foreground. In light theme that left dark text sitting
                                                     directly on the blue AccentBrush background — same fix as the
                                                     badge just below, which already did this correctly. -->
                                                <TextBlock Text="{Binding Label}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Badge deliberately swaps to the opposite brush pair when the nav item
                                                     is active: the button's own Tag="Active" trigger (NavButton style)
                                                     paints its background with AccentBrush, which is also this badge's
                                                     default background — left as-is, the badge visually disappears into
                                                     the now-same-color button the moment its own page is selected. -->
                                                <Border CornerRadius="8" Padding="6,0" MinWidth="16" Margin="6,0,0,0"
                                                        Visibility="{Binding BadgeCount, Converter={StaticResource CountToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource TextOnAccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding BadgeCount}" FontSize="10" FontWeight="Bold"
                                                               HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- "sidebar" display mode (default) — see Настройки → Быстрый доступ for
                                 the "top" alternative (horizontal bubble dock above the page content,
                                 ContentColumn below) and ConfigService.QuickAppsDisplayMode. -->
                            <StackPanel Visibility="{Binding QuickAppsSidebarVisible, Converter={StaticResource BoolToVis}}">
                                <Separator Margin="0,8,0,8"/>
                                <TextBlock Text="БЫСТРЫЙ ДОСТУП" Style="{StaticResource MutedText}" Margin="12,0,0,4" FontSize="10"/>
                                <ItemsControl ItemsSource="{Binding QuickApps}" Margin="8,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource NavButton}"
                                                    Margin="0,0,0,2" HorizontalAlignment="Stretch"
                                                    Command="{Binding LaunchCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,8,0"
                                                           Visibility="{Binding IconSource, Converter={StaticResource NullToVis}}"/>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content placement is CONDITIONAL on whether the top quick-apps bar is showing, rather
                 than fixed with an overlay:
                   • No top bar (QuickAppsTopVisible false — "sidebar" mode / no quick apps): content
                     spans Row 0 + Row 1, so the page reaches all the way up to the window's top edge
                     and doesn't leave an empty gap the height of the sidebar's own logo/role band
                     (that band only exists on the sidebar side; content has nothing of its own to
                     justify matching it). Spanning the Auto row (0) with the Star row (1) is safe —
                     WPF does NOT let a Star+Auto-spanning child inflate the Auto row, so Row 0 still
                     sizes to exactly the sidebar header's height.
                   • Top bar visible ("top"/"top_labeled"): content sits in Row 1 ONLY, so the page
                     starts BELOW the icon bar. Earlier this relied on the bar's opaque background +
                     Panel.ZIndex painting over content that still spanned Row 0 — but that only HID
                     the top of the page behind the bar (clipped it), it never pushed the page down,
                     so enabling quick-apps swallowed the top strip of the functional content. Moving
                     content out of Row 0 when the bar is present is the actual reflow. -->
            <Border Grid.Column="1" Background="{DynamicResource BgBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Grid.Row" Value="0"/>
                        <Setter Property="Grid.RowSpan" Value="2"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QuickAppsTopVisible}" Value="True">
                                <Setter Property="Grid.Row" Value="1"/>
                                <Setter Property="Grid.RowSpan" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ContentControl Content="{Binding CurrentPageContent}"/>
            </Border>
        </Grid>

        <!-- Status bar. Здесь же — единственный индикатор фоновой работы (BusyTracker): пока
             программа синхронизируется с диском, копирует прошивку или отправляет конфиг, снизу
             видно, ЧТО именно идёт. До этого фоновые операции выполнялись прямо на потоке
             интерфейса и молча: окно переставало отвечать, и это было неотличимо от «зависла». -->
        <Border Grid.Row="7" Background="{DynamicResource BgSidebarBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,1,0,0">
            <Grid Margin="10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                           HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,16,0"
                            Visibility="{Binding Busy.IsBusy, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="90" Height="6" VerticalAlignment="Center" Maximum="100"
                                 IsIndeterminate="{Binding Busy.IsIndeterminate}" Value="{Binding Busy.Progress}"/>
                    <TextBlock Text="{Binding Busy.Text}" Style="{StaticResource MutedText}" Margin="8,0,0,0"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding DiskStatusText}" Style="{StaticResource MutedText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Onboarding tour overlay — sits on top of everything, only populated while the tour runs -->
        <ContentControl x:Name="OnboardingHost" Grid.Row="0" Grid.RowSpan="8" Focusable="False"/>
    </Grid>
</Window>
