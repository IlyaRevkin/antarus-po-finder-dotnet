<Window x:Class="AntarusPoFinder.App.Views.PhoneNetworkInstructionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Подключение папки осмотра с телефона" Width="560" Height="520" MinWidth="440" MinHeight="360"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Подключение папки осмотра с телефона" Style="{StaticResource TitleText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="BodyText" TextWrapping="Wrap" Style="{StaticResource SubtitleText}"/>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Закрыть" IsCancel="True" Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Right" Width="100" Margin="0,16,0,0" Click="Close_Click"/>
    </Grid>
</Window>
