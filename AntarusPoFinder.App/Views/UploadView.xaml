<UserControl x:Class="AntarusPoFinder.App.Views.UploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntarusPoFinder.App.Views">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Загрузка прошивки" Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: drop zone + preview. Scrollable — with the HMI drop zone expanded,
                 this column's content can be taller than the window (esp. in windowed/non-maximized
                 mode), and without a ScrollViewer the bottom buttons ("Очистить данные" etc.) become
                 unreachable with no way to scroll down to them. -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <StackPanel x:Name="ReservationPanel" Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock Text="ИСПОЛЬЗОВАТЬ ЗАРЕЗЕРВИРОВАННЫЙ НОМЕР" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ReservationCombo" Height="36" DisplayMemberPath="Label" SelectionChanged="ReservationCombo_SelectionChanged"
                              ToolTip="Если для этого шкафа/подтипа/контроллера есть открытый резерв номера — выберите его, чтобы загрузка использовала ровно тот номер, который уже вписан в прошивку."/>
                </StackPanel>

                <!-- Раздельные зоны ПЛК/HMI — поведение по умолчанию, без изменений. Свёрнуты в
                     отдельную панель, а не удалены/переписаны, специально: чтобы включение единой
                     зоны (см. UnifiedZonePanel ниже) не могло случайно затронуть этот блок — это
                     ровно тот же XAML/код, что был здесь до бета-функции. Какая из двух панелей
                     видна, решает UploadView.ApplyUnifiedZoneMode (читает Cfg.UnifiedPlcHmiZoneEnabled,
                     перечитывается при каждом открытии страницы — см. ReloadCombos). -->
                <StackPanel x:Name="ClassicZonesPanel">
                    <Border x:Name="DropZone" Style="{StaticResource DropZoneBorder}" Height="130" Cursor="Hand"
                            AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver" MouseLeftButtonUp="DropZone_Click">
                        <TextBlock x:Name="DropZoneLabel" Text="Перетащите файл, папку или несколько файлов сюда&#x0a;&#x0a;или нажмите для выбора"
                                   Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Файл..." Style="{StaticResource SecondaryButton}" Click="BrowseFile_Click"/>
                        <Button Grid.Column="2" Content="Папка..." Style="{StaticResource SecondaryButton}" Click="BrowseFolder_Click"/>
                    </Grid>

                    <CheckBox x:Name="HmiCheck" Content="Добавить HMI-проект (отдельно от ПЛК, напр. .fsprj)" Margin="0,12,0,0"
                              Checked="HmiCheck_Toggled" Unchecked="HmiCheck_Toggled"
                              ToolTip="Для контроллеров, где HMI — отдельный проект со своими файлами (напр. Segnetics), а не часть основного файла прошивки.&#x0a;HMI прикладывается к версии прошивки — файл/папка прошивки ПЛК всё равно нужно выбрать выше."/>
                    <!-- Same drag&drop-zone-plus-buttons shape as the main firmware DropZone above (see
                         round 43 — a plain label+textbox row here, matching the ДОП. ФАЙЛЫ attachments
                         instead, silently lost drag&drop entirely: dropping an HMI folder anywhere near
                         this area landed on the MAIN drop zone above instead, which then tried to find a
                         firmware-recognized file in it — the real cause behind reports of "загрузил
                         HMI-папку, а он спрашивает про psl" — now fixed by giving HMI its own drop zone
                         plus an HMI-specific executable-picker message, see OnHmiPathPicked/
                         PromptExecutableHint in UploadView.xaml.cs). Shorter
                         (70 vs 130) since it's a secondary/optional field, not the primary upload target.
                         HmiSection (not just HmiPathRow) toggles with the checkbox now that the drop zone
                         itself is also part of the collapsible block. -->
                    <StackPanel x:Name="HmiSection" Margin="0,6,0,0" Visibility="Collapsed">
                        <Border x:Name="HmiDropZone" Style="{StaticResource DropZoneBorder}" Height="70" Cursor="Hand"
                                AllowDrop="True" Drop="HmiDropZone_Drop" DragOver="HmiDropZone_DragOver" MouseLeftButtonUp="HmiDropZone_Click">
                            <TextBlock x:Name="HmiPathLabel" Text="Перетащите файл, папку или несколько файлов HMI-проекта сюда&#x0a;или нажмите для выбора"
                                       Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Файл..." Style="{StaticResource CompactSecondaryButton}" Click="HmiBrowseFile_Click"/>
                            <Button Grid.Column="2" Content="Папка..." Style="{StaticResource CompactSecondaryButton}" Click="HmiBrowseFolder_Click"/>
                            <Button Grid.Column="4" Content="Очистить" Style="{StaticResource CompactSecondaryButton}" Click="HmiClear_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Единая зона ПЛК+HMI (бета) — включается галочкой в Настройки → Общие →
                     ЗАГРУЗКА (программист/администратор). Одна drag&drop-зона принимает и файл/папку
                     ПЛК, и HMI-проект — по расширению файла UploadView.xaml.cs сам решает, куда что
                     положить (_srcPath/_hmiPath), а если не может решить однозначно — переспрашивает
                     диалогом (см. ClassifyAndAssignOne/AskPlcOrHmi). Дальше всё как обычно: _srcPath →
                     SourcePath, _hmiPath → HmiSourcePath, FirmwareUploadService не меняется. -->
                <StackPanel x:Name="UnifiedZonePanel" Visibility="Collapsed">
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource WarningBrush}">
                            <Run Text="⚠ БЕТА: единая зона ПЛК+HMI." FontWeight="SemiBold"/>
                            <Run Text=" Кидайте файл/папку прошивки ПЛК и (опционально) HMI-проект сюда — вместе или по очереди. Приложение попробует определить, что есть что, по расширению файла; если не сможет — переспросит. Если распознавание ошиблось — очистите нужную строку ниже кнопкой «✕» и укажите файл заново."/>
                        </TextBlock>
                    </Border>
                    <Border x:Name="UnifiedDropZone" Style="{StaticResource DropZoneBorder}" Height="130" Cursor="Hand"
                            AllowDrop="True" Drop="UnifiedDropZone_Drop" DragOver="UnifiedDropZone_DragOver" MouseLeftButtonUp="UnifiedDropZone_Click">
                        <TextBlock Text="Перетащите файл(ы)/папку прошивки ПЛК и HMI-проекта сюда&#x0a;&#x0a;или нажмите для выбора  —  БЕТА"
                                   Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Файлы..." Style="{StaticResource SecondaryButton}" Click="UnifiedBrowseFiles_Click"/>
                        <Button Grid.Column="2" Content="Папка..." Style="{StaticResource SecondaryButton}" Click="UnifiedBrowseFolder_Click"/>
                        <Button Grid.Column="4" Content="Очистить всё" Style="{StaticResource SecondaryButton}" Click="UnifiedClearAll_Click"/>
                    </Grid>

                    <!-- Что распознано — две строки-превью с индивидуальной очисткой/переназначением
                         (переназначить = просто кинуть новый файл поверх, он заменит текущий, как и в
                         раздельных зонах выше; «✕» — очистить конкретно эту строку). -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="UnifiedPlcPreviewText" Text="ПЛК: не выбрано" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="UnifiedPlcClearBtn" Style="{StaticResource IconButton}" IsEnabled="False" Margin="6,0,0,0" Click="UnifiedPlcClear_Click" ToolTip="Очистить ПЛК">
                                    <Path Data="{StaticResource Icon.Close}" Stretch="Uniform" Width="12" Height="12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                                </Button>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="UnifiedHmiPreviewText" Text="HMI: не выбрано (опционально)" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="UnifiedHmiClearBtn" Style="{StaticResource IconButton}" IsEnabled="False" Margin="6,0,0,0" Click="UnifiedHmiClear_Click" ToolTip="Очистить HMI">
                                    <Path Data="{StaticResource Icon.Close}" Stretch="Uniform" Width="12" Height="12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Text="ПУТЬ НА ДИСКЕ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                <Border Style="{StaticResource CardBorder}">
                    <TextBlock x:Name="PreviewLabel" Text="—" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                </Border>

                <Button x:Name="ReserveVersionBtn" Content="Зарезервировать номер версии" Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"
                        Click="ReserveVersion_Click"
                        ToolTip="Зафиксировать следующий номер версии заранее — чтобы вписать его в прошивку до сборки и не рисковать, что номер уйдёт вперёд, пока идёт разработка."/>

                <Button Content="Очистить данные" Style="{StaticResource SecondaryButton}" Margin="0,6,0,8"
                        Click="ClearData_Click" ToolTip="Сбросить выбранный файл и все поля формы (если загружен не тот файл)"/>
            </StackPanel>
            </ScrollViewer>

            <!-- Right column: metadata form -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="МЕТАДАННЫЕ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Ширина колонки-подписи — 100, ровно как у «Карта in/out»/«Карта modbus»/
                         «Инструкция» в блоке ДОП. ФАЙЛЫ ниже (раньше здесь было 130, из-за чего поля
                         № заявки/SN шкафа начинались на 30px правее, чем всё остальное на странице).
                         Заголовки секций и панели чекбоксов вынесены в Column 0 со ColumnSpan 2 —
                         раньше они сидели в Column 1, т.е. с отступом 130px, тогда как «МЕТАДАННЫЕ»,
                         «ДОП. ФАЙЛЫ», «Изменения в этой версии» и drag&drop-зона слева начинаются от
                         левого края. Именно это и выглядело как «отступы разъезжаются». -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Тип шкафа + Подтип(ы) + Контроллер — все три в ОДНОМ ряду. Раньше подтип
                             жил отдельной строкой ниже во всю ширину (единый чек-комбобокс
                             SubtypeMultiSelect добавили позже, чем сложился этот ряд, и его просто
                             дописали снизу) — это читалось так, будто подтип не относится к типу
                             шкафа/контроллеру, хотя смысл ровно тот же "короткое значение из
                             справочника", что и у соседей. Вернули все три поля в один ряд; описание
                             выбранного контроллера (CtrlDescLabel) теперь отдельной строкой ПОД
                             Контроллером (последняя пара колонок), а не под Типом шкафа слева — это
                             подпись именно контроллера. -->
                        <!-- Комбо-колонки — proportional (star) с Min/MaxWidth, не фиксированный
                             пиксельный Width — эта строка живёт в узкой правой колонке двухколоночной
                             страницы (левая — 340px drop-zone/preview), фиксированная ширина переполняла
                             бы окно в неразвёрнутом виде (см. ParamsView, где та же строка шире — там
                             вся ширина страницы). Star-размер даёт WPF сжимать все три колонки вместе
                             вместо переполнения, MaxWidth не даёт им раздуться шире исходного вида,
                             когда места достаточно. При MainWindow.MinWidth=1100 на правую колонку
                             остаётся ~650-700px — трёх коротких полей (мин. по 80-90px каждое) это
                             свободно вмещает без переноса. -->
                        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="80" MaxWidth="170"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="90" MaxWidth="190"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="90" MaxWidth="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип шкафа *:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Тип шкафа (группа оборудования):&#x0a;  НГР — насосная группа&#x0a;  ПЖ — пожарное водоснабжение&#x0a;  ТГР — тепловая группа"/>
                            <ComboBox x:Name="GroupCombo" Grid.Row="0" Grid.Column="1" Height="34"
                                      DisplayMemberPath="Name" SelectionChanged="GroupCombo_SelectionChanged"/>

                            <!-- Основной И дополнительные подтипы — один чек-комбобокс
                                 (SubtypeMultiSelect): первый отмеченный становится основным (задаёт
                                 номер версии, папку на диске и резерв — как раньше отдельный ComboBox
                                 SubCombo), остальные отмеченные — дополнительные (им заводится своя
                                 запись, а на диск кладётся ярлык на ту же папку версии, без
                                 дублирования файлов). Та же высота (34), что у соседних ComboBox —
                                 стоит компактно между Типом и Контроллером, а не отдельной полноширинной
                                 строкой. -->
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Подтип(ы) *:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Первый отмеченный — основной: задаёт папку на диске, номер версии и резерв. Остальные отмеченные — дополнительные: файл не дублируется, в их папки кладётся ярлык."/>
                            <views:SubtypeMultiSelect x:Name="SubtypesSelect" Grid.Row="0" Grid.Column="4" Height="34" SelectionChanged="SubtypesSelect_SelectionChanged"/>

                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Контроллер *:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="PIXEL2 DI/DO/AI/AO указаны в описании модификации"/>
                            <ComboBox x:Name="CtrlCombo" Grid.Row="0" Grid.Column="7" Height="34"
                                      DisplayMemberPath="DisplayName" SelectionChanged="CtrlCombo_SelectionChanged"/>

                            <!-- Описание выбранного контроллера — строго под полем Контроллера (те же
                                 две последние колонки), а не под Типом шкафа: это подпись контроллера,
                                 а не типа шкафа, и должна визуально принадлежать своему полю. -->
                            <TextBlock Grid.Row="1" Grid.Column="6" Grid.ColumnSpan="2" x:Name="CtrlDescLabel" Text="" Style="{StaticResource MutedText}"
                                       FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Отдельный заголовок вместо инлайновой подписи слева — тот же паттерн, что
                             у "ДОП. ФАЙЛЫ И ДОП. НАСТРОЙКИ"/"МЕТАДАННЫЕ" по всей странице, вместо
                             ряда с подписью в левой узкой колонке, как было — Тип пуска обязателен и
                             концептуально другого рода поле (не переключатель поведения формы, а сама
                             загружаемая метаданные), стоило визуально отделить от подтипов выше. -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="ТИП ПУСКА *" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,10,0,6"/>
                        <!-- Раньше это был отдельный горизонтальный StackPanel ВНЕ этой сетки, из-за
                             чего чекбоксы типа пуска висели по своим правилам отступов и не
                             переносились на узком окне (тот же класс бага, что уже чинили у «ОПЦИИ
                             ВЕРСИИ», см. VersionOptionsPanel — теперь внутри ExtrasExpander ниже, но
                             WrapPanel-приём тот же). Такой же WrapPanel в такой же ячейке сетки с теми
                             же Margin. -->
                        <WrapPanel x:Name="LaunchTypesPanel" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6"/>
                    </Grid>

                    <TextBlock Text="Изменения в этой версии *:" Margin="0,10,0,4"/>
                    <TextBox x:Name="DescInput" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <!-- Единый свёрнутый по умолчанию раздел "ДОП. ФАЙЛЫ И ДОП. НАСТРОЙКИ" — объединяет
                         то, что раньше было тремя разными местами на странице (свой Expander "ОПЦИИ
                         ВЕРСИИ", три всегда-развёрнутых ряда доп.файлов, отдельная строка "Теги"), в
                         один блок. Цель — компактность: на минимальном окне (MainWindow MinHeight=720)
                         обязательная часть формы выше (метаданные, подтипы, тип пуска, описание) и
                         кнопка "Загрузить" ниже должны помещаться без прокрутки, а всё необязательное —
                         под одним кликом. SectionExpander (см. Styles.xaml) — тот же приём, что и у
                         старого VersionOptionsExpander (обычный WPF Expander не годится, чужеродный
                         светлый хром на тёмной теме), просто с более крупным содержимым. -->
                    <Expander x:Name="ExtrasExpander" Style="{StaticResource SectionExpander}" Margin="0,10,0,8">
                        <Expander.Header>
                            <!-- Обычной подписи оказалось недостаточно — на живом прогоне пользователь
                                 не понял, что по заголовку можно кликнуть и раздел раскроется (родной
                                 шеврон SectionExpander мелкий, 12px). Оборачиваем в заметную полосу-Border
                                 с крупной стрелкой и явной подсказкой "нажмите, чтобы развернуть/
                                 свернуть"; текст стрелки/подсказки меняется местами в
                                 ExtrasExpander_Expanded/Collapsed (UploadView.xaml.cs). Родной шеврон
                                 SectionExpander скрыт (Visibility="Collapsed" в самом шаблоне, см.
                                 Styles.xaml) именно из-за этой замены — иначе рисовались бы ДВЕ стрелки
                                 одновременно (родная мелкая + эта крупная). Курсор-рука для всей полосы
                                 уже даёт сам ToggleButton в шаблоне SectionExpander — Border ниже её не
                                 переопределяет, просто наследует. -->
                            <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                                    BorderThickness="1" CornerRadius="4" Padding="10,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ExtrasHeaderArrow" Text="▸" FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="ДОП. ФАЙЛЫ И ДОП. НАСТРОЙКИ" Style="{StaticResource MutedText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ExtrasHeaderHint" Text="  —  нажмите, чтобы развернуть" Style="{StaticResource MutedText}"
                                               FontStyle="Italic" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Expander.Header>
                        <StackPanel>
                            <!-- Опции версии — дата/штамп времени и признак нестандартного (ОПЦ) шкафа.
                                 WrapPanel, не горизонтальный StackPanel — при минимальной ширине окна
                                 три чекбокса шире доступной колонки, а WrapPanel просто переносит третий
                                 на свою строку вместо обрезания (тот самый баг с нечитаемым "ОПЦ SN",
                                 который уже чинили здесь раньше). -->
                            <TextBlock Text="ОПЦИИ ВЕРСИИ" Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,4"/>
                            <WrapPanel x:Name="VersionOptionsPanel" Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="IncludeDateCheck" Content="Дата/время в номере версии" IsChecked="True" Margin="0,0,20,4"
                                          Checked="IncludeDate_Toggled" Unchecked="IncludeDate_Toggled"
                                          ToolTip="Если выключено, номер версии не содержит дату и время сборки (eq.sub.hw.sw без штампа)."/>
                                <CheckBox x:Name="OpcReqNumCheck" Content="ОПЦ заявка" Margin="0,0,16,4"
                                          Checked="OpcReqNum_Toggled" Unchecked="OpcReqNum_Toggled"
                                          ToolTip="Нестандартный шкаф с номером заявки — активирует поле № заявки, имя файла получает суффикс (номер)."/>
                                <CheckBox x:Name="OpcSnCheck" Content="ОПЦ SN" Margin="0,0,0,4"
                                          Checked="OpcSn_Toggled" Unchecked="OpcSn_Toggled"
                                          ToolTip="Нестандартный шкаф с серийным номером — активирует поле SN шкафа, имя файла получает суффикс SNxxxxx."/>
                            </WrapPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="ReqNumLabel" Text="№ заявки:" VerticalAlignment="Center" Margin="0,0,4,0" Visibility="Collapsed"/>
                                <TextBox Grid.Column="1" x:Name="ReqNumInput" Height="34"
                                         Visibility="Collapsed" ToolTip="напр. 1312 — в имени файла будет дополнен нулями до 5 цифр" TextChanged="ReqNum_Changed"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="CabinetSnLabel" Text="SN шкафа:" VerticalAlignment="Center" Margin="0,0,4,0" Visibility="Collapsed"/>
                                <TextBox Grid.Column="1" x:Name="CabinetSnInput" Height="34"
                                         Visibility="Collapsed" ToolTip="Заводской серийный номер шкафа (независимо от № заявки) — в имени файла будет суффикс SNxxxxx" TextChanged="CabinetSn_Changed"/>
                            </Grid>

                            <!-- Доп. файлы — три плитки-слота вместо трёх полноширинных рядов
                                 label+TextBox+3 кнопки (см. FileSlotController и стиль FileSlot в
                                 Styles.xaml). Сами TextBox (IoMapInput/ModbusMapInput/InstructionsInput)
                                 никуда не делись — просто Visibility="Collapsed": это по-прежнему
                                 единственный носитель пути, который читает FirmwareUploadService через
                                 BuildUploadRequest, плитка лишь пишет/читает его .Text. Порядок и
                                 подписи — как в исходных трёх рядах: Карта ВВ, Карта modbus,
                                 Инструкция. -->
                            <TextBlock Text="ДОП. ФАЙЛЫ" Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" x:Name="IoMapSlot" Style="{StaticResource FileSlot}" Height="64"
                                        ToolTip="Карта ВВ — копируется в папку контроллера &quot;Карта ВВ&quot;. Необязательное поле.&#x0a;Перетащите файл или папку сюда, либо нажмите для выбора.">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Карта ВВ" Style="{StaticResource MutedText}" FontSize="10" FontWeight="SemiBold"/>
                                            <Button Grid.Column="1" x:Name="IoMapSlotClear" Style="{StaticResource TagRemoveButton}" Content="×"
                                                    Visibility="Collapsed" Margin="4,-6,-6,0" ToolTip="Очистить"/>
                                        </Grid>
                                        <TextBlock Grid.Row="1" x:Name="IoMapSlotText" Text="+ файл" FontSize="11" TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="2" x:Name="ModbusMapSlot" Style="{StaticResource FileSlot}" Height="64"
                                        ToolTip="Карта modbus — копируется в папку контроллера &quot;Карта Modbus&quot;. Необязательное поле.&#x0a;Перетащите файл или папку сюда, либо нажмите для выбора.">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Карта modbus" Style="{StaticResource MutedText}" FontSize="10" FontWeight="SemiBold"/>
                                            <Button Grid.Column="1" x:Name="ModbusMapSlotClear" Style="{StaticResource TagRemoveButton}" Content="×"
                                                    Visibility="Collapsed" Margin="4,-6,-6,0" ToolTip="Очистить"/>
                                        </Grid>
                                        <TextBlock Grid.Row="1" x:Name="ModbusMapSlotText" Text="+ файл" FontSize="11" TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="4" x:Name="InstructionsSlot" Style="{StaticResource FileSlot}" Height="64"
                                        ToolTip="Инструкция — копируется в папку контроллера &quot;Инструкция&quot;. Необязательное поле.&#x0a;Перетащите файл или папку сюда, либо нажмите для выбора.">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Инструкция" Style="{StaticResource MutedText}" FontSize="10" FontWeight="SemiBold"/>
                                            <Button Grid.Column="1" x:Name="InstructionsSlotClear" Style="{StaticResource TagRemoveButton}" Content="×"
                                                    Visibility="Collapsed" Margin="4,-6,-6,0" ToolTip="Очистить"/>
                                        </Grid>
                                        <TextBlock Grid.Row="1" x:Name="InstructionsSlotText" Text="+ файл" FontSize="11" TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Скрытые носители значения — см. комментарий выше про FileSlotController.
                                 Остаются обычными TextBox с теми же x:Name, что и раньше, только без
                                 собственного UI: FirmwareUploadService/BuildUploadRequest продолжают
                                 читать их .Text, ничего в контракте загрузки не меняется. -->
                            <TextBox x:Name="IoMapInput" Visibility="Collapsed"/>
                            <TextBox x:Name="ModbusMapInput" Visibility="Collapsed"/>
                            <TextBox x:Name="InstructionsInput" Visibility="Collapsed"/>

                            <TextBlock Text="ТЕГИ" Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,4"/>
                            <views:TagBubbleEditor x:Name="TagsEditor"/>
                        </StackPanel>
                    </Expander>

                    <TextBlock x:Name="StatusLabel" Text="" Style="{StaticResource SubtitleText}" Margin="0,8,0,8" TextWrapping="Wrap"/>

                    <Button x:Name="UploadBtn" Content="Загрузить прошивку" Height="40" Click="Upload_Click"/>
                    <Button x:Name="RollbackBtn" Content="Откатить последнюю версию" Style="{StaticResource SecondaryButton}" Margin="0,8,0,0" Click="Rollback_Click"
                            ToolTip="Пометить последнюю активную прошивку для выбранного шкафа/подтипа/контроллера как откатанную. Следующая загрузка получит тот же SW-номер заново. Файлы на диске не удаляются."/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
