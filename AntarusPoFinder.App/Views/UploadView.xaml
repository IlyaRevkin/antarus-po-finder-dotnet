<UserControl x:Class="AntarusPoFinder.App.Views.UploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntarusPoFinder.App.Views">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Загрузка прошивки" Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: drop zone + preview. Scrollable — with the HMI drop zone expanded,
                 this column's content can be taller than the window (esp. in windowed/non-maximized
                 mode), and without a ScrollViewer the bottom buttons ("Очистить данные" etc.) become
                 unreachable with no way to scroll down to them. -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <StackPanel x:Name="ReservationPanel" Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock Text="ИСПОЛЬЗОВАТЬ ЗАРЕЗЕРВИРОВАННЫЙ НОМЕР" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ReservationCombo" Height="36" DisplayMemberPath="Label" SelectionChanged="ReservationCombo_SelectionChanged"
                              ToolTip="Если для этого шкафа/подтипа/контроллера есть открытый резерв номера — выберите его, чтобы загрузка использовала ровно тот номер, который уже вписан в прошивку."/>
                </StackPanel>

                <Border x:Name="DropZone" Style="{StaticResource DropZoneBorder}" Height="130" Cursor="Hand"
                        AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver" MouseLeftButtonUp="DropZone_Click">
                    <TextBlock x:Name="DropZoneLabel" Text="Перетащите файл, папку или несколько файлов сюда&#x0a;&#x0a;или нажмите для выбора"
                               Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Файл..." Style="{StaticResource SecondaryButton}" Click="BrowseFile_Click"/>
                    <Button Grid.Column="2" Content="Папка..." Style="{StaticResource SecondaryButton}" Click="BrowseFolder_Click"/>
                </Grid>

                <CheckBox x:Name="HmiCheck" Content="Добавить HMI-проект (отдельно от ПЛК, напр. .fsprj)" Margin="0,12,0,0"
                          Checked="HmiCheck_Toggled" Unchecked="HmiCheck_Toggled"
                          ToolTip="Для контроллеров, где HMI — отдельный проект со своими файлами (напр. Segnetics), а не часть основного файла прошивки.&#x0a;HMI прикладывается к версии прошивки — файл/папка прошивки ПЛК всё равно нужно выбрать выше."/>
                <!-- Same drag&drop-zone-plus-buttons shape as the main firmware DropZone above (see
                     round 43 — a plain label+textbox row here, matching the ДОП. ФАЙЛЫ attachments
                     instead, silently lost drag&drop entirely: dropping an HMI folder anywhere near
                     this area landed on the MAIN drop zone above instead, which then tried to find a
                     firmware-recognized file in it — the real cause behind reports of "загрузил
                     HMI-папку, а он спрашивает про psl" — now fixed by giving HMI its own drop zone
                     plus an HMI-specific executable-picker message, see OnHmiPathPicked/
                     PromptExecutableHint in UploadView.xaml.cs). Shorter
                     (70 vs 130) since it's a secondary/optional field, not the primary upload target.
                     HmiSection (not just HmiPathRow) toggles with the checkbox now that the drop zone
                     itself is also part of the collapsible block. -->
                <StackPanel x:Name="HmiSection" Margin="0,6,0,0" Visibility="Collapsed">
                    <Border x:Name="HmiDropZone" Style="{StaticResource DropZoneBorder}" Height="70" Cursor="Hand"
                            AllowDrop="True" Drop="HmiDropZone_Drop" DragOver="HmiDropZone_DragOver" MouseLeftButtonUp="HmiDropZone_Click">
                        <TextBlock x:Name="HmiPathLabel" Text="Перетащите файл, папку или несколько файлов HMI-проекта сюда&#x0a;или нажмите для выбора"
                                   Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Файл..." Style="{StaticResource CompactSecondaryButton}" Click="HmiBrowseFile_Click"/>
                        <Button Grid.Column="2" Content="Папка..." Style="{StaticResource CompactSecondaryButton}" Click="HmiBrowseFolder_Click"/>
                        <Button Grid.Column="4" Content="Очистить" Style="{StaticResource CompactSecondaryButton}" Click="HmiClear_Click"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="ПУТЬ НА ДИСКЕ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                <Border Style="{StaticResource CardBorder}">
                    <TextBlock x:Name="PreviewLabel" Text="—" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                </Border>

                <Button x:Name="ReserveVersionBtn" Content="Зарезервировать номер версии" Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"
                        Click="ReserveVersion_Click"
                        ToolTip="Зафиксировать следующий номер версии заранее — чтобы вписать его в прошивку до сборки и не рисковать, что номер уйдёт вперёд, пока идёт разработка."/>

                <Button Content="Очистить данные" Style="{StaticResource SecondaryButton}" Margin="0,6,0,8"
                        Click="ClearData_Click" ToolTip="Сбросить выбранный файл и все поля формы (если загружен не тот файл)"/>
            </StackPanel>
            </ScrollViewer>

            <!-- Right column: metadata form -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="МЕТАДАННЫЕ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Ширина колонки-подписи — 100, ровно как у «Карта in/out»/«Карта modbus»/
                         «Инструкция» в блоке ДОП. ФАЙЛЫ ниже (раньше здесь было 130, из-за чего поля
                         № заявки/SN шкафа начинались на 30px правее, чем всё остальное на странице).
                         Заголовки секций и панели чекбоксов вынесены в Column 0 со ColumnSpan 2 —
                         раньше они сидели в Column 1, т.е. с отступом 130px, тогда как «МЕТАДАННЫЕ»,
                         «ДОП. ФАЙЛЫ», «Изменения в этой версии» и drag&drop-зона слева начинаются от
                         левого края. Именно это и выглядело как «отступы разъезжаются». -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Тип шкафа + Контроллер side by side, one row — values here are always short
                             (НГР, ХП, SMH4…), so stretching each combo across the whole form width like
                             a free-text field wasted most of a wide column on empty space. Подтип раньше
                             стоял тут же третьей короткой колонкой (обычный ComboBox) — теперь это
                             отдельная строка ниже с единым чек-комбобоксом (SubtypesSelect), где
                             одновременно выбираются и основной, и дополнительные подтипы, так что для
                             него нужна вся ширина, а не треть строки. -->
                        <!-- Комбо-колонки — proportional (star) с Min/MaxWidth, не фиксированный
                             пиксельный Width — эта строка живёт в узкой правой колонке двухколоночной
                             страницы (левая — 340px drop-zone/preview), фиксированная ширина переполняла
                             бы окно в неразвёрнутом виде (см. ParamsView, где та же строка шире — там
                             вся ширина страницы). Star-размер даёт WPF сжимать обе колонки вместе вместо
                             переполнения, MaxWidth не даёт им раздуться шире исходного вида, когда места
                             достаточно. -->
                        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="90" MaxWidth="220"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="90" MaxWidth="220"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип шкафа *:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Тип шкафа (группа оборудования):&#x0a;  НГР — насосная группа&#x0a;  ПЖ — пожарное водоснабжение&#x0a;  ТГР — тепловая группа"/>
                            <ComboBox x:Name="GroupCombo" Grid.Column="1" Height="34"
                                      DisplayMemberPath="Name" SelectionChanged="GroupCombo_SelectionChanged"/>
                            <TextBlock Grid.Column="3" Text="Контроллер *:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="PIXEL2 DI/DO/AI/AO указаны в описании модификации"/>
                            <ComboBox x:Name="CtrlCombo" Grid.Column="4" Height="34"
                                      DisplayMemberPath="DisplayName" SelectionChanged="CtrlCombo_SelectionChanged"/>
                        </Grid>

                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="CtrlDescLabel" Text="" Style="{StaticResource MutedText}"
                                   FontSize="11" Margin="0,2,0,6" TextWrapping="Wrap"/>

                        <!-- Основной И дополнительные подтипы — теперь ОДИН чек-комбобокс
                             (SubtypeMultiSelect): первый отмеченный становится основным (задаёт номер
                             версии, папку на диске и резерв — как раньше отдельный ComboBox SubCombo),
                             остальные отмеченные — дополнительные (им заводится своя запись, а на диск
                             кладётся ярлык на ту же папку версии, без дублирования файлов). Раньше это
                             были два разных виджета в двух разных строках; см. SubtypesSelect_
                             SelectionChanged ниже — тот же каскад (резерв/превью пути), что раньше
                             висел на SubCombo_SelectionChanged. -->
                        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Подтип(ы) *:" VerticalAlignment="Center" Margin="0,0,6,0"
                                       ToolTip="Первый отмеченный — основной: задаёт папку на диске, номер версии и резерв. Остальные отмеченные — дополнительные: файл не дублируется, в их папки кладётся ярлык."/>
                            <views:SubtypeMultiSelect Grid.Column="1" x:Name="SubtypesSelect" Height="34" SelectionChanged="SubtypesSelect_SelectionChanged"/>
                        </Grid>

                        <!-- Опции версии — дата/штамп времени и признак нестандартного (ОПЦ) шкафа —
                             используются далеко не в каждой загрузке, но раньше занимали три строки
                             высоты всегда, даже когда все три чекбокса выключены. Свёрнуты в Expander
                             по умолчанию (SectionExpander, см. Styles.xaml — обычный WPF Expander не
                             использован по той же причине, что и у SidebarExpanderHeader: чужеродный
                             светлый хром на тёмной теме) — раскрывается кликом по заголовку, когда
                             реально нужен нестандартный шкаф или отключение штампа даты в номере. -->
                        <Expander x:Name="VersionOptionsExpander" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                  Style="{StaticResource SectionExpander}" Margin="0,4,0,6">
                            <Expander.Header>
                                <TextBlock Text="ОПЦИИ ВЕРСИИ" Style="{StaticResource MutedText}" FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel>
                                <!-- WrapPanel, not a horizontal StackPanel — at the app's own MinWidth this
                                     row's three checkboxes are wider than the available column (the right
                                     column of UploadView's two-column page, further narrowed by the
                                     ScrollViewer's own vertical scrollbar), and a horizontal StackPanel
                                     doesn't clip gracefully: it just gets cut off by the ScrollViewer
                                     (HorizontalScrollBarVisibility is Disabled here, no horizontal scroll to
                                     reach the rest), rendering "ОПЦ SN" as an unreadable/unclickable sliver
                                     ("O") at min window width (verified live). WrapPanel wraps the third
                                     checkbox onto its own line only when space is actually short. -->
                                <WrapPanel x:Name="VersionOptionsPanel" Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox x:Name="IncludeDateCheck" Content="Дата/время в номере версии" IsChecked="True" Margin="0,0,20,4"
                                              Checked="IncludeDate_Toggled" Unchecked="IncludeDate_Toggled"
                                              ToolTip="Если выключено, номер версии не содержит дату и время сборки (eq.sub.hw.sw без штампа)."/>
                                    <CheckBox x:Name="OpcReqNumCheck" Content="ОПЦ заявка" Margin="0,0,16,4"
                                              Checked="OpcReqNum_Toggled" Unchecked="OpcReqNum_Toggled"
                                              ToolTip="Нестандартный шкаф с номером заявки — активирует поле № заявки, имя файла получает суффикс (номер)."/>
                                    <CheckBox x:Name="OpcSnCheck" Content="ОПЦ SN" Margin="0,0,0,4"
                                              Checked="OpcSn_Toggled" Unchecked="OpcSn_Toggled"
                                              ToolTip="Нестандартный шкаф с серийным номером — активирует поле SN шкафа, имя файла получает суффикс SNxxxxx."/>
                                </WrapPanel>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" x:Name="ReqNumLabel" Text="№ заявки:" VerticalAlignment="Center" Margin="0,0,4,0" Visibility="Collapsed"/>
                                    <TextBox Grid.Column="1" x:Name="ReqNumInput" Height="34"
                                             Visibility="Collapsed" ToolTip="напр. 1312 — в имени файла будет дополнен нулями до 5 цифр" TextChanged="ReqNum_Changed"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" x:Name="CabinetSnLabel" Text="SN шкафа:" VerticalAlignment="Center" Margin="0,0,4,0" Visibility="Collapsed"/>
                                    <TextBox Grid.Column="1" x:Name="CabinetSnInput" Height="34"
                                             Visibility="Collapsed" ToolTip="Заводской серийный номер шкафа (независимо от № заявки) — в имени файла будет суффикс SNxxxxx" TextChanged="CabinetSn_Changed"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Отдельный заголовок вместо инлайновой подписи слева — тот же паттерн, что
                             у "ОПЦИИ ВЕРСИИ" выше и у "ДОП. ФАЙЛЫ"/"МЕТАДАННЫЕ" по всей странице, вместо
                             ряда с подписью в левой узкой колонке, как было — Тип пуска обязателен и
                             концептуально другого рода поле (не переключатель поведения формы, а сама
                             загружаемая метаданные), стоило визуально отделить от блока опций выше. -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="ТИП ПУСКА *" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,6,0,6"/>
                        <!-- Раньше это был отдельный горизонтальный StackPanel ВНЕ этой сетки, из-за
                             чего чекбоксы типа пуска висели по своим правилам отступов и не
                             переносились на узком окне (тот же класс бага, что уже чинили у «ОПЦИИ
                             ВЕРСИИ»). Теперь — такой же WrapPanel в такой же ячейке сетки с теми же
                             Margin, что у VersionOptionsPanel выше. -->
                        <WrapPanel x:Name="LaunchTypesPanel" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6"/>
                    </Grid>

                    <TextBlock Text="Изменения в этой версии *:" Margin="0,10,0,4"/>
                    <TextBox x:Name="DescInput" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Теги:" Margin="0,10,0,4"/>
                    <views:TagBubbleEditor x:Name="TagsEditor"/>

                    <TextBlock Text="ДОП. ФАЙЛЫ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,14,0,8"/>
                    <!-- Карта in/out, Карта modbus и Инструкция — три одинаковых полноширинных ряда
                         (label/textbox/3 icon buttons), а не «Карта in/out» + «Карта modbus» бок о бок
                         в паре плюс отдельная полноширинная «Инструкция». Парой они экономили строку
                         высоты, но кнопки Файл/Папка/Очистить у пары стояли примерно на 50% ширины
                         карточки, а у «Инструкции» — на 100%: три ряда кнопок на разных x читались как
                         неаккуратная вёрстка. Теперь у всех трёх рядов одна и та же ширина колонки-
                         подписи (100) и одна и та же раскладка столбцов — кнопки всех трёх рядов стоят
                         на одном x. Страница внутри ScrollViewer (см. выше), так что лишняя строка
                         высоты не выталкивает форму за пределы окна — просто чуть больше скролла. -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Карта in/out:" VerticalAlignment="Center" TextWrapping="Wrap"
                                   ToolTip="Копируется в папку контроллера &quot;Карта ВВ&quot;. Необязательное поле."/>
                        <TextBox Grid.Column="1" x:Name="IoMapInput" Height="34" Margin="0,0,4,0"/>
                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="IoMapBrowseFile_Click" ToolTip="Выбрать файл">
                            <Path Data="{StaticResource Icon.File}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="IoMapBrowseFolder_Click" ToolTip="Выбрать папку">
                            <Path Data="{StaticResource Icon.Folder}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="IoMapClear_Click" ToolTip="Очистить">
                            <Path Data="{StaticResource Icon.Close}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Карта modbus:" VerticalAlignment="Center" TextWrapping="Wrap"
                                   ToolTip="Копируется в папку контроллера &quot;Карта Modbus&quot;. Необязательное поле."/>
                        <TextBox Grid.Column="1" x:Name="ModbusMapInput" Height="34" Margin="0,0,4,0"/>
                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="ModbusMapBrowseFile_Click" ToolTip="Выбрать файл">
                            <Path Data="{StaticResource Icon.File}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="ModbusMapBrowseFolder_Click" ToolTip="Выбрать папку">
                            <Path Data="{StaticResource Icon.Folder}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="ModbusMapClear_Click" ToolTip="Очистить">
                            <Path Data="{StaticResource Icon.Close}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Инструкция:" VerticalAlignment="Center"
                                   ToolTip="Копируется в папку контроллера &quot;Инструкция&quot;. Необязательное поле."/>
                        <TextBox Grid.Column="1" x:Name="InstructionsInput" Height="34" Margin="0,0,4,0"/>
                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="InstructionsBrowseFile_Click" ToolTip="Выбрать файл">
                            <Path Data="{StaticResource Icon.File}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="InstructionsBrowseFolder_Click" ToolTip="Выбрать папку">
                            <Path Data="{StaticResource Icon.Folder}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource IconButton}" Margin="2,0,0,0" Click="InstructionsClear_Click" ToolTip="Очистить">
                            <Path Data="{StaticResource Icon.Close}" Stretch="Uniform" Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                        </Button>
                    </Grid>

                    <TextBlock x:Name="StatusLabel" Text="" Style="{StaticResource SubtitleText}" Margin="0,8,0,8" TextWrapping="Wrap"/>

                    <Button x:Name="UploadBtn" Content="Загрузить прошивку" Height="40" Click="Upload_Click"/>
                    <Button x:Name="RollbackBtn" Content="Откатить последнюю версию" Style="{StaticResource SecondaryButton}" Margin="0,8,0,0" Click="Rollback_Click"
                            ToolTip="Пометить последнюю активную прошивку для выбранного шкафа/подтипа/контроллера как откатанную. Следующая загрузка получит тот же SW-номер заново. Файлы на диске не удаляются."/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
