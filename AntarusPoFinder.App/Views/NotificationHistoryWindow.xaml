<Window x:Class="AntarusPoFinder.App.Views.NotificationHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Уведомления" Width="480" Height="640"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с подзаголовком — на всю ширину, отдельной строкой. Раньше он делил строку с
             кнопками (star-колонка слева, две Auto-кнопки справа): в узком окне (480px) кнопки
             «⚙ Настройки» + «Очистить уведомления» съедали место, star-колонка сжималась уже самого
             заголовка, и «История уведомлений» (без переноса/обрезки) вылезал за свою колонку прямо
             поверх кнопок — та самая жалоба «кнопки перекрывают текст». Теперь заголовок ни с чем по
             ширине не конкурирует, а кнопки — строкой ниже, прижаты вправо. -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="История уведомлений" Style="{StaticResource TitleText}" Margin="0,0,0,4" TextWrapping="Wrap"/>
            <TextBlock Text="Всё, что показывалось в статус-баре или баннером сверху — включая уже скрывшееся."
                       Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Category on/off + unread-count controls collapsed behind a toggle by default, same
             pattern as InspectionView's "⚙ Настройки осмотра" — they used to sit permanently at
             the top of this window (a settings block above the actual notification list every
             time it opened), crowding the one thing the window is mostly opened for: reading the
             history. -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
            <Button x:Name="CategorySettingsToggle" Content="⚙ Настройки" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="CategorySettingsToggle_Click"/>
            <Button Content="Очистить уведомления" Style="{StaticResource SecondaryButton}"
                    Click="ClearAll_Click"/>
        </StackPanel>

        <Border Grid.Row="2" x:Name="CategorySettingsPanel" Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="КАТЕГОРИИ УВЕДОМЛЕНИЙ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="«Показывать» — снятая галка полностью отключает категорию на этом ПК: уведомление не появится нигде, включая эту историю. «Считать непрочитанным» — категория продолжает появляться и попадать в историю, но не увеличивает счётчик на кнопке «Уведомления»."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Показывать" Style="{StaticResource MutedText}" FontSize="11" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Считать непрочитанным" Style="{StaticResource MutedText}" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
                <StackPanel x:Name="NotificationCategoriesPanel"/>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="3" x:Name="ListBoxHistory" BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0,8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush2}">
                        <!-- DockPanel вместо Grid с колонками Auto/Auto/*/Auto — реальная причина
                             наезда текста на кнопку была не в отсутствии обрезки (ClipToBounds
                             это не лечит), а в самой раскладке: внутри виртуализированного ListBox
                             звёздная колонка Grid с TextWrapping-содержимым может получить неверно
                             посчитанную ширину (известная особенность двухпроходного алгоритма
                             звёздных колонок Grid — TextBlock меряется по одной ширине, а
                             отрисовывается по другой), и тогда его граница на самом деле заезжает
                             в соседнюю Auto-колонку с кнопкой. ClipToBounds обрезает элемент по
                             ЕГО ЖЕ (уже неверно широким) границам — то есть ничего не спасает,
                             если сама граница колонки посчитана неправильно, что и наблюдалось
                             живьём. DockPanel считает ширины иначе: сначала «пристыкованные»
                             элементы (время, бейдж — слева; кнопка — Dock="Right", т.е. её
                             фиксированная по содержимому ширина «вычитается» из доступного места
                             первой), и только потом весь остаток ширины отдаётся заполняющему
                             (последнему, без Dock) элементу — тексту. Это один детерминированный
                             проход без пересчётов, поэтому кнопка гарантированно получает свою
                             ширину, а тексту физически не может достаться больше места, чем
                             осталось — переносится он ДО кнопки, а не под неё. -->
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding WhenLabel}" Style="{StaticResource MutedText}"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <!-- Category badge — clickable, opens the per-category settings panel above
                                 (item 9: "no way to configure per-category behavior directly from a
                                 notification"). Not just decorative text: this is the reachable path
                                 from a notification row to its category's on/off and unread-count
                                 switches. -->
                            <Border DockPanel.Dock="Left" Background="{DynamicResource BgCardBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,10,0"
                                    VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="CategoryBadge_Click"
                                    ToolTip="Настроить эту категорию уведомлений">
                                <TextBlock Text="{Binding CategoryLabel}" Style="{StaticResource MutedText}" FontSize="11"/>
                            </Border>
                            <!-- Кнопка пристыкована справа (DockPanel.Dock="Right") — своя,
                                 фиксированная по содержимому ширина, всегда у правого края строки;
                                 её место вычитается из доступной ширины ДО того, как текст ниже
                                 получает свой остаток, так что она физически не может оказаться
                                 под текстом или наоборот. -->
                            <Button DockPanel.Dock="Right" Content="Показать" Style="{StaticResource SecondaryButton}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding CanReopen, Converter={StaticResource BoolToVis}}" Click="Reopen_Click"/>
                            <!-- Заполняющий элемент (последний, без Dock) — вся оставшаяся ширина
                                 строки. Правый отступ — небольшой зазор перед кнопкой, чтобы перенос
                                 срабатывал чуть раньше её левого края, а не впритык. ClipToBounds
                                 оставлен как страховка на редкий экстремальный случай (сама
                                 раскладка теперь корректна и без неё), но в норме уже не требуется. -->
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,0,10,0" VerticalAlignment="Center"
                                       ClipToBounds="True" Foreground="{DynamicResource TextBrush}"/>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
