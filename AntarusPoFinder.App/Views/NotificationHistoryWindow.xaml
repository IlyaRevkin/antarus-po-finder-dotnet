<Window x:Class="AntarusPoFinder.App.Views.NotificationHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Уведомления" Width="480" Height="640"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="История уведомлений" Style="{StaticResource TitleText}" Margin="0,0,0,4"/>
                <TextBlock Text="Всё, что показывалось в статус-баре или баннером сверху — включая уже скрывшееся."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
            </StackPanel>
            <!-- Category on/off + unread-count controls collapsed behind a toggle by default, same
                 pattern as InspectionView's "⚙ Настройки осмотра" — they used to sit permanently at
                 the top of this window (a settings block above the actual notification list every
                 time it opened), crowding the one thing the window is mostly opened for: reading the
                 history. -->
            <Button Grid.Column="1" x:Name="CategorySettingsToggle" Content="⚙ Настройки" Style="{StaticResource SecondaryButton}"
                    VerticalAlignment="Top" Margin="0,0,8,0" Click="CategorySettingsToggle_Click"/>
            <Button Grid.Column="2" Content="Очистить уведомления" Style="{StaticResource SecondaryButton}"
                    VerticalAlignment="Top" Click="ClearAll_Click"/>
        </Grid>

        <Border Grid.Row="1" x:Name="CategorySettingsPanel" Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="КАТЕГОРИИ УВЕДОМЛЕНИЙ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="«Показывать» — снятая галка полностью отключает категорию на этом ПК: уведомление не появится нигде, включая эту историю. «Считать непрочитанным» — категория продолжает появляться и попадать в историю, но не увеличивает счётчик на кнопке «Уведомления»."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Показывать" Style="{StaticResource MutedText}" FontSize="11" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Считать непрочитанным" Style="{StaticResource MutedText}" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
                <StackPanel x:Name="NotificationCategoriesPanel"/>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="2" x:Name="ListBoxHistory" BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0,8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush2}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding WhenLabel}" Style="{StaticResource MutedText}"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <!-- Category badge — clickable, opens the per-category settings panel above
                                 (item 9: "no way to configure per-category behavior directly from a
                                 notification"). Not just decorative text: this is the reachable path
                                 from a notification row to its category's on/off and unread-count
                                 switches. -->
                            <Border Grid.Column="1" Background="{DynamicResource BgCardBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,10,0"
                                    VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="CategoryBadge_Click"
                                    ToolTip="Настроить эту категорию уведомлений">
                                <TextBlock Text="{Binding CategoryLabel}" Style="{StaticResource MutedText}" FontSize="11"/>
                            </Border>
                            <!-- ClipToBounds — WPF Grid does NOT clip a child to its own cell when the
                                 child's desired width exceeds it: this text column is a Star column,
                                 fine for wrapping normal sentences, but a single unbroken long token
                                 (a firmware filename, a version string, a path — exactly what shows up
                                 in a lot of this app's status messages) can't be wrapped at all and was
                                 rendering past this column's right edge, straight over the "Показать"
                                 button in Column="3" next to it. Clipping to this element's own arranged
                                 bounds keeps that overflow inside its own column instead of on top of
                                 the button — the rare long token gets hard-cut rather than overlapping,
                                 which is the safe outcome here. -->
                            <TextBlock Grid.Column="2" Text="{Binding Text}" TextWrapping="Wrap" VerticalAlignment="Center"
                                       ClipToBounds="True" Foreground="{DynamicResource TextBrush}"/>
                            <Button Grid.Column="3" Content="Показать" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                    Visibility="{Binding CanReopen, Converter={StaticResource BoolToVis}}" Click="Reopen_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
