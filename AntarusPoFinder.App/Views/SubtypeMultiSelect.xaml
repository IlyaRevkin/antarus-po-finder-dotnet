<UserControl x:Class="AntarusPoFinder.App.Views.SubtypeMultiSelect"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Комбобокс с чекбоксами: выглядит и открывается как обычный ComboBox (та же окантовка/стрелка,
         что в теме приложения — см. Styles.xaml, стиль ComboBox), но вместо выбора одного пункта
         отмечает несколько и не закрывается по клику на чекбокс. Popup вместо настоящего ComboBox —
         у ComboBox закрытие по выбору пункта встроено в шаблон и не отключается без полной замены
         шаблона; Popup даёт то же самое (тень, позиционирование под полем), но открытием/закрытием
         управляем сами. -->
    <Grid x:Name="RootGrid">
        <Border x:Name="MainBorder" Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="6" Cursor="Hand" MouseLeftButtonUp="MainBorder_MouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SummaryText" Grid.Column="0" Margin="8,6" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextBrush}"/>
                <Path Grid.Column="1" Data="M4,7 L10,13 L16,7" Stroke="{DynamicResource TextBrush}"
                      StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      StrokeLineJoin="Round" Margin="0,0,10,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Popup x:Name="ItemsPopup" PlacementTarget="{Binding ElementName=MainBorder}" Placement="Bottom"
               StaysOpen="False" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide"
               Width="{Binding ElementName=MainBorder, Path=ActualWidth}">
            <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1" CornerRadius="6" Margin="0,4,0,0" MaxHeight="260">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,4">
                    <StackPanel x:Name="ItemsPanel" Margin="4,0"/>
                </ScrollViewer>
            </Border>
        </Popup>
    </Grid>
</UserControl>
