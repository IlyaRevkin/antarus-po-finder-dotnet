<UserControl x:Class="AntarusPoFinder.App.Views.CopyableVersionText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TextBlock x:Name="Label" Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
               Cursor="Hand" ToolTip="Нажмите, чтобы скопировать"
               MouseLeftButtonUp="Label_Click" VerticalAlignment="Center"/>
</UserControl>
