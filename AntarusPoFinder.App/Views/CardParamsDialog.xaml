<Window x:Class="AntarusPoFinder.App.Views.CardParamsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Параметры" Width="480" Height="400" MinWidth="360" MinHeight="280"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0" x:Name="FilesList" DisplayMemberPath="Display"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Открыть" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Open_Click"/>
            <Button Content="Папка" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenFolder_Click"/>
            <Button Content="В протокол" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="ToProtocol_Click"/>
            <Button Content="Закрыть" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
