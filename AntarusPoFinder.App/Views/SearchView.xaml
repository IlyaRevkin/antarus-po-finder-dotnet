<UserControl x:Class="AntarusPoFinder.App.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Поиск" Style="{StaticResource TitleText}" Margin="0,0,0,12"/>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SearchInput" Height="38" Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     ToolTip="Введите название шкафа — напр. «НГР КПЧ SMH5» или «ПЖ KINCO»"
                     KeyDown="SearchInput_KeyDown"/>
            <Button Grid.Column="1" Content="Найти" Height="38" Width="100" Click="Search_Click"/>
            <Button Grid.Column="2" x:Name="FiltersToggle" Content="Фильтры ▾" Style="{StaticResource SecondaryButton}"
                    Height="38" Margin="8,0,0,0" Click="ToggleFilters_Click"
                    ToolTip="Сузить выдачу по типу шкафа, подтипу, контроллеру или типу пуска"/>
            <Button Grid.Column="3" Content="Сбросить поиск" Style="{StaticResource SecondaryButton}" Height="38" Margin="8,0,0,0" Click="ResetSearch_Click"/>
        </Grid>

        <!-- Панель фильтров: свёрнута по умолчанию — кнопок в поиске и так хватает, а фильтры
             нужны не каждый раз. Пустой запрос с заданными фильтрами — осмысленный «покажи всё
             такое», см. SearchView.PerformFirmwareSearch. -->
        <Border x:Name="FiltersPanel" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,10"
                Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel>
                <!-- Единая ширина колонки (170) на все четыре фильтра — раньше у каждого комбобокса
                     было своё случайное значение (170/170/150/130/230), и ряд выглядел рваным,
                     особенно после переноса на вторую строку в узком окне. Ширина задана на
                     StackPanel-обёртке, а не на самом ComboBox — только так и подпись, и поле
                     растягиваются на одинаковую ширину колонки. -->
                <WrapPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="Тип шкафа" Style="{StaticResource MutedText}"/>
                        <ComboBox x:Name="FilterGroupCombo" Height="30" DisplayMemberPath="Label"
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="Подтип" Style="{StaticResource MutedText}"/>
                        <ComboBox x:Name="FilterSubtypeCombo" Height="30" DisplayMemberPath="Label"
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="Контроллер" Style="{StaticResource MutedText}"/>
                        <ComboBox x:Name="FilterControllerCombo" Height="30" DisplayMemberPath="Label"
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="Тип пуска" Style="{StaticResource MutedText}"/>
                        <ComboBox x:Name="FilterLaunchCombo" Height="30" DisplayMemberPath="Label"
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <!-- Как и у SecondaryButton, вертикальный Padding (8+8) плюс рамка (1+1) требуют
                         примерно 34px на содержимое — жёсткий Height="28" (как у соседних
                         ComboBox-полей ряда) не уменьшал этот padding, а просто обрезал
                         ContentPresenter, из-за чего надпись "Сбросить фильтры" была видна не целиком.
                         CompactSecondaryButton — тот же вид кнопки с уменьшенным padding и MinHeight
                         вместо Height (см. её комментарий в Styles.xaml, сделана ровно для этого
                         случая: компактный ряд кнопок рядом с невысокими полями) — кнопка становится
                         на пару пикселей выше соседних комбобоксов, но текст внутри не обрезается. -->
                    <Button Content="Сбросить фильтры" Style="{StaticResource CompactSecondaryButton}"
                            VerticalAlignment="Bottom" Margin="0,0,0,8" Click="ResetFilters_Click"/>
                </WrapPanel>
                <!-- Поиск по тегу теперь идёт из обычной строки поиска (см. SearchInput) — тег с
                     точным совпадением слова сворачивает выдачу до одной прошивки, см.
                     Database.SearchFwVersions. Отдельного фильтра «Тег» здесь больше нет. -->
                <TextBlock x:Name="FiltersHint" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                           Text="Фильтры действуют только для поиска по прошивкам. С пустым запросом покажет всё, что подходит под фильтры. Поиск по тегу — прямо в строке поиска (с «Точное совпадение слова» найдёт ровно нужный шкаф)."/>
            </StackPanel>
        </Border>

        <!-- Search mode: firmware vs. parameter files vs. cabinet schematics (second disk) — one
             three-way sliding toggle (ModeThumb glides under the checked segment) instead of three
             separately-styled pill buttons. -->
        <StackPanel x:Name="ModeSelectorPanel" Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Border CornerRadius="15" Padding="3" Margin="0,0,16,0"
                    Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                <Grid>
                    <Border x:Name="ModeThumb" Width="150" Height="26" CornerRadius="13"
                            Background="{DynamicResource AccentBrush}" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ModeThumbTransform" X="0"/>
                        </Border.RenderTransform>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="FwModeRadio" GroupName="SearchMode" Style="{StaticResource SearchModeSegment}"
                                     Content="Прошивки" Width="150" Height="26" IsChecked="True" Checked="SearchMode_Changed"/>
                        <RadioButton x:Name="ParamsModeRadio" GroupName="SearchMode" Style="{StaticResource SearchModeSegment}"
                                     Content="Параметры ПЧ/УПП" Width="150" Height="26" Checked="SearchMode_Changed"/>
                        <RadioButton x:Name="SchemasModeRadio" GroupName="SearchMode" Style="{StaticResource SearchModeSegment}"
                                     Content="Схемы" Width="150" Height="26" Checked="SearchMode_Changed"
                                     ToolTip="Поиск электросхем шкафов на втором диске — по всем папкам, частичное совпадение по названию"/>
                    </StackPanel>
                </Grid>
            </Border>
            <CheckBox x:Name="ExactWordCheck" Content="Точное совпадение слова" VerticalAlignment="Center"
                      ToolTip="Например, чтобы «ПЧ» не находило «КПЧ» — совпадение только по целому слову"
                      Checked="SearchMode_Changed" Unchecked="SearchMode_Changed"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="StatusLabel" Style="{StaticResource SubtitleText}" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
            <Grid>
                <TextBlock x:Name="EmptyLabel" Text="Введите запрос и нажмите «Найти»" Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0"/>
                <StackPanel x:Name="ResultsPanel"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
