<Window x:Class="AntarusPoFinder.App.Views.HistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AntarusPoFinder.App.Views"
        Icon="/Assets/icon.ico"
        Title="История версий" Width="720" Height="520" MinWidth="600" MinHeight="400"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GridSplitter Grid.Row="0" Height="0"/>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" x:Name="VersionsGrid" AutoGenerateColumns="False"
                      SelectionChanged="VersionsGrid_SelectionChanged" MouseDoubleClick="VersionsGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Версия" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <views:CopyableVersionText Text="{Binding VersionRaw}" Margin="6,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Дата" Binding="{Binding DateDisplay}" Width="130"/>
                    <DataGridTextColumn Header="Контроллер" Binding="{Binding CtrlName}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusLabel}" Width="140"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding DescriptionShort}" Width="*"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsRolledBack}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource RolledBackBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TextBox Grid.Row="2" x:Name="DetailText" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Margin="0,4,0,0"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Развернуть" Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,8,0" Click="Maximize_Click"/>
            <Button Content="Закрыть" IsCancel="True" Width="100" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
