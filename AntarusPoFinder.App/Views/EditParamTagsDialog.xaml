<Window x:Class="AntarusPoFinder.App.Views.EditParamTagsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AntarusPoFinder.App.Views"
        Icon="/Assets/icon.ico"
        Width="480" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="TitleLabel" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <TextBlock Text="Теги:" Margin="0,0,0,4"/>
        <views:TagBubbleEditor x:Name="TagsEditor" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="90" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
