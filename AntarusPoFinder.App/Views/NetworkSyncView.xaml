<UserControl x:Class="AntarusPoFinder.App.Views.NetworkSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Сетевые диски и синхронизация" Style="{StaticResource TitleText}" Margin="0,0,0,4"/>
            <TextBlock Text="Эти настройки — про то, где лежат файлы и как часто общий конфиг (справочник оборудования, теги, резервы номеров) обновляется на этом компьютере. Доступны всем ролям, так как каждый настраивает свой компьютер сам."
                       Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,20"/>

            <TextBlock Text="ПУТЬ К ДИСКУ (WEBDAV / СЕТЕВАЯ ПАПКА)" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="RootPathInput" Height="34" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="…" Style="{StaticResource SecondaryButton}" Width="34" Margin="0,0,8,0" Click="BrowseRoot_Click"/>
                <Button Grid.Column="2" Content="Сохранить" Click="SaveRoot_Click"/>
            </Grid>

            <TextBlock Text="ВТОРОЙ ДИСК (ШКАФЫ И ЭЛЕКТРОСХЕМЫ)" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SecondDiskInput" Height="34" Margin="0,0,8,0" ToolTip="Путь к папке с кабинетами (шкафами)"/>
                <Button Grid.Column="1" Content="…" Style="{StaticResource SecondaryButton}" Width="34" Margin="0,0,8,0" Click="BrowseSecondDisk_Click"/>
                <Button Grid.Column="2" Content="Сохранить" Click="SaveSecondDisk_Click"/>
            </Grid>

            <TextBlock Text="ПАПКА ОСМОТРА" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock Text="Сюда сохраняются сканы, фото по QR и файлы, накопленные во время осмотра оборудования."
                       Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="InspectionFolderInput" Height="34" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="…" Style="{StaticResource SecondaryButton}" Width="34" Margin="0,0,8,0" Click="BrowseInspectionFolder_Click"/>
                <Button Grid.Column="2" Content="Сохранить" Click="SaveInspectionFolder_Click"/>
            </Grid>

            <!-- Автоочистка папки осмотра переехала в саму вкладку "Осмотр" (InspectionView) — логичнее
                 настраивать её там же, где видна сама папка, а не в Сетевых дисках. -->

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="ПОЛУЧЕНИЕ ОБНОВЛЕНИЙ КОНФИГА" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <!-- Задача 2: раньше здесь был настраиваемый интервал опроса (sync_interval_min) —
                         убран, потому что новая система синхронизации подтягивает изменения сама:
                         маркер ревизии проверяется на фиксированном коротком интервале (см.
                         MainWindowViewModel._revisionPollTimer, ~75 сек) плюс мгновенно по событию
                         изменения файла (FileSystemWatcher на revision.json, best-effort — не на
                         каждой сетевой шаре поддерживается уведомлениями). Настраиваемый интервал
                         делал ровно ту же дешёвую проверку, просто реже и без выигрыша — поле убрано
                         из интерфейса, сама настройка (и таймер, который её ещё уважает) в коде
                         осталась нетронутой на случай отладки. -->
                    <TextBlock Text="Справочник оборудования, теги и резервы номеров, изменённые кем-то другим на общем диске, подтягиваются на этот компьютер автоматически — как только на диске появляется новая версия, без подтверждения вручную."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="SyncNowButton" Content="Синхронизировать сейчас" Style="{StaticResource SecondaryButton}" Click="SyncNow_Click" Margin="0,0,12,0"/>
                        <TextBlock x:Name="LastSyncText" Text="" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Ручная кнопка выше — подстраховка на случай, если диск на минуту отвалился: автоматика и так проверяет обновления регулярно."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" FontStyle="Italic" Margin="0,4,0,0"/>
                    <TextBlock x:Name="LastCheckText" Text="" Style="{StaticResource MutedText}" FontStyle="Italic" Margin="0,4,0,0"
                               ToolTip="Обновляется на каждой фоновой проверке, даже если изменений на диске не нашлось — если эта отметка не сдвигается, фоновая проверка не запускается вовсе; если сдвигается, а «Последняя синхронизация» выше — нет, изменений на диске просто не найдено."/>
                    <TextBlock x:Name="RevisionText" Text="" Style="{StaticResource MutedText}" FontStyle="Italic" Margin="0,2,0,0"
                               ToolTip="Ревизия маркера Конфиг\revision.json, которую эта машина уже применила — по ней проверка обновлений понимает, тянуть ли конфиг целиком, без сравнения по часам."/>
                    <StackPanel x:Name="ConflictStatusPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="ConflictStatusText" Text="" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Показать и решить" Style="{StaticResource SecondaryButton}" Click="ShowConflicts_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Only administrator sees this — everyone else only pulls, see RefreshIfActive() -->
            <Border x:Name="PushSection" Style="{StaticResource CardBorder}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="ОТПРАВКА ИЗМЕНЕНИЙ НА ДИСК" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <!-- Задача 2: интервал ниже (config_push_interval_min) НЕ убран, в отличие от
                         интервала получения выше — он не дублирует ничего автоматического. Каждое
                         изменение справочника (тип шкафа, тег, производитель и т.п.) отправляется на
                         диск сразу же, само по себе (см. MainWindowViewModel.PushCatalogChange) — этот
                         интервал только подстраховка на случай, если тот немедленный пуш не удался
                         (диск был недоступен в момент правки): периодически досылает накопленное. -->
                    <TextBlock Text="Изменения справочника (иерархия, теги, резервы) отправляются на общий диск сразу же, как только их сделали. Интервал ниже — не основной механизм, а подстраховка: если в момент правки диск был недоступен, накопленные изменения досылаются повторно с этим интервалом."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Каждые" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="PushIntervalInput" Width="64" Height="34" Margin="0,0,8,0"/>
                        <TextBlock Text="минут" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Сохранить" Style="{StaticResource SecondaryButton}" Click="SavePushInterval_Click"/>
                    </StackPanel>
                    <TextBlock Text="0 — подстраховочная автоотправка отключена (ручная кнопка «Отправить сейчас» ниже всё равно работает)."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" FontStyle="Italic" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Отправить сейчас" Style="{StaticResource SecondaryButton}" Click="PushNow_Click" Margin="0,0,12,0"/>
                        <TextBlock x:Name="LastPushText" Text="" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Эталонная синхронизация (authoritative push) — полная замена справочника у
                         всех получателей, а не аддитивная отправка выше. Опасная, редкая операция,
                         поэтому визуально отделена рамкой ErrorBrush и подтверждается отдельным
                         жёстким диалогом (см. PushAuthoritative_Click) перед самой отправкой. -->
                    <Border BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="ЭТАЛОННАЯ СИНХРОНИЗАЦИЯ" Style="{StaticResource MutedText}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedText}" Margin="0,0,0,10"
                                       Text="Сделать справочник этой машины (типы шкафов, подтипы, контроллеры, модификации, производители ПЧ/УПП, теги, разрешённые расширения) образцом для всех остальных компьютеров: то, чего здесь нет, будет удалено и у них. Прошивки и файлы параметров не затрагиваются."/>
                            <Button x:Name="PushAuthoritativeButton" Content="Сделать это состояние эталонным для всех"
                                    Style="{StaticResource DangerButton}" Click="PushAuthoritative_Click" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
