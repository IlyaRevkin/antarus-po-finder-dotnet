<UserControl x:Class="AntarusPoFinder.App.Views.InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Осмотр" Style="{StaticResource TitleText}" Margin="0,0,0,12"/>

        <!-- Protocol folder toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Папка осмотра:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" x:Name="ProtoPathLabel" Text="не задана" Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="2" Content="Открыть папку" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="OpenProtocolFolder_Click"/>
                <Button Grid.Column="3" Content="Сканировать" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="ScanDocument_Click"
                        ToolTip="Использует сохранённое качество сканирования — настраивается ниже, в «Настройки осмотра»."/>
                <!-- Redundant "Очистить папку осмотра" button removed from here — same action lives in
                     the settings drawer below, right next to the auto-cleanup interval it's a manual
                     override of, which is a more natural place for it than the main toolbar. -->
                <Button Grid.Column="5" x:Name="InspectionSettingsToggle" Content="⚙ Настройки осмотра" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="InspectionSettingsToggle_Click"/>
            </Grid>

            <!-- Автоочистка/качество сканирования — редко трогаемые настройки "один раз задал и забыл",
                 убраны за переключатель вместо постоянного места на панели инструментов, чтобы не
                 загромождать основную область страницы. Same collapsed-by-default toggle-button
                 pattern as ParamsView's "Все загруженные"/ListContentPanel. -->
            <Border Grid.Row="1" x:Name="InspectionSettingsPanel" Style="{StaticResource CardBorder}" Margin="0,8,0,0" Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Качество сканирования:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ScanResolutionCombo" Width="90" VerticalAlignment="Center"
                                  ToolTip="DPI скана — выше значение, чётче скан, но больше размер файла"
                                  SelectionChanged="ScanResolutionCombo_SelectionChanged">
                            <ComboBoxItem Content="100"/>
                            <ComboBoxItem Content="150"/>
                            <ComboBoxItem Content="200"/>
                            <ComboBoxItem Content="300"/>
                            <ComboBoxItem Content="600"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Автоочистка папки осмотра:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="InspectionCleanupDaysInput" Width="40" Height="30" VerticalContentAlignment="Center" Margin="0,0,2,0" ToolTip="Дни"/>
                        <TextBlock Text="дн." VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="InspectionCleanupHoursInput" Width="40" Height="30" VerticalContentAlignment="Center" Margin="0,0,2,0" ToolTip="Часы"/>
                        <TextBlock Text="ч." VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="InspectionCleanupMinutesInput" Width="40" Height="30" VerticalContentAlignment="Center" Margin="0,0,2,0" ToolTip="Минуты"/>
                        <TextBlock Text="мин." VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="SaveInspectionCleanupDays_Click"/>
                        <Button Content="Очистить сейчас" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="ClearProtocolFolder_Click"/>
                    </StackPanel>
                    <TextBlock Text="0/0/0 — отключено. Иначе файлы старше указанного времени периодически удаляются автоматически (при запуске и вместе с фоновой синхронизацией)."
                               Style="{StaticResource MutedText}" FontStyle="Italic" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- QR panel: always visible while the tab is open (not a popup dialog) -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" VerticalAlignment="Top" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Фото с телефона" Style="{StaticResource SubtitleText}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Image x:Name="QrImage" Width="200" Height="200" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="QrInfoText" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" Style="{StaticResource MutedText}"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"
                               Foreground="{DynamicResource WarningBrush}" FontWeight="SemiBold"
                               Text="⚠ Телефон должен быть в той же Wi-Fi сети, что и этот компьютер — иначе QR-код не откроется."/>
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" HorizontalAlignment="Stretch" Click="PhoneInstructions_Click">
                        <TextBlock Text="Как подключить папку с телефона" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Inspection folder file list -->
            <Grid Grid.Column="1" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="FileCountText" Text="Файлы" Style="{StaticResource SubtitleText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Обновить" Style="{StaticResource SecondaryButton}" Click="Refresh_Click"/>
                </Grid>
                <ListBox Grid.Row="1" x:Name="FilesList" SelectionMode="Extended" MouseDoubleClick="FilesList_MouseDoubleClick"
                         SelectionChanged="FilesList_SelectionChanged"
                         PreviewMouseRightButtonDown="FilesList_PreviewMouseRightButtonDown">
                    <ListBox.ContextMenu>
                        <ContextMenu Opened="FilesContextMenu_Opened">
                            <MenuItem x:Name="OpenFileMenuItem" Header="Открыть файл" Click="OpenFile_Click"/>
                            <MenuItem x:Name="OpenFolderMenuItem" Header="Открыть папку" Click="OpenContainingFolder_Click"/>
                            <Separator/>
                            <MenuItem x:Name="DeleteMenuItem" Header="Удалить файл" Click="DeleteFile_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" Margin="12,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Preview pane: like Windows Explorer's — updates on single click, no popup -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="PreviewTitleText" Text="Предпросмотр" Style="{StaticResource SubtitleText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Удалить файл" Style="{StaticResource DangerButton}" Click="DeleteFile_Click"/>
                </Grid>

                <!-- Image toolbar: only shown while an image is selected (see FilesList_SelectionChanged).
                     Compact icon buttons — rotate carries less weight than the preview itself, so it
                     shouldn't crowd the toolbar; view-only (no save/overwrite — Осмотр is a working
                     folder, this pane never mutates the file on disk). Small enough now that it fits in
                     one row even at the window's MinWidth, unlike the earlier text-button version. -->
                <StackPanel Grid.Row="1" x:Name="ImageEditToolbar" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
                    <Button Content="⟲" Style="{StaticResource IconButton}" Margin="0,0,4,0" ToolTip="Повернуть влево" Click="RotateLeft_Click"/>
                    <Button Content="⟳" Style="{StaticResource IconButton}" Margin="0,0,16,0" ToolTip="Повернуть вправо" Click="RotateRight_Click"/>
                    <Button Content="−" Style="{StaticResource IconButton}" Margin="0,0,4,0" ToolTip="Уменьшить" Click="ZoomOut_Click"/>
                    <TextBlock x:Name="ZoomLevelText" Text="По размеру окна" VerticalAlignment="Center"
                               Width="100" TextAlignment="Center" Style="{StaticResource MutedText}"/>
                    <Button Content="+" Style="{StaticResource IconButton}" Margin="4,0,4,0" ToolTip="Увеличить" Click="ZoomIn_Click"/>
                    <Button Content="⤢" Style="{StaticResource IconButton}" ToolTip="По размеру окна" Click="ZoomFit_Click"/>
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                    <Grid x:Name="PreviewHost">
                        <TextBlock x:Name="PreviewPlaceholder" Text="Выберите файл в списке слева"
                                   Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ScrollViewer x:Name="PreviewImageScroll" Visibility="Collapsed"
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      SizeChanged="PreviewImageScroll_SizeChanged">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="PreviewImage" RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="PreviewImageScale" ScaleX="1" ScaleY="1"/>
                                    </Image.LayoutTransform>
                                </Image>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
