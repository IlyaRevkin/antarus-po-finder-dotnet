<Window x:Class="AntarusPoFinder.App.Views.TextPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Width="360" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="LabelText" Margin="0,0,0,4"/>
        <TextBox x:Name="Input" Margin="0,0,0,16" KeyDown="Input_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="ОК" Width="90" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
