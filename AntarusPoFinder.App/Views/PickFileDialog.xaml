<Window x:Class="AntarusPoFinder.App.Views.PickFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Width="420" SizeToContent="Height" MaxHeight="480"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="LabelText" Margin="0,0,0,8" TextWrapping="Wrap"/>
        <ListBox x:Name="FilesList" MaxHeight="280" MouseDoubleClick="FilesList_MouseDoubleClick"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Пропустить" Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,8,0" Click="Skip_Click"/>
            <Button Content="ОК" Width="90" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
