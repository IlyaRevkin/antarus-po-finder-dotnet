<UserControl x:Class="AntarusPoFinder.App.Views.FirmwareCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntarusPoFinder.App.Views">
    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Cursor="Hand" MouseLeftButtonUp="Header_Click"
                        ToolTip="Нажмите, чтобы скопировать номер версии (имя файла на диске)">
                <TextBlock x:Name="NameLabel" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="   "/>
                <TextBlock x:Name="VersionLabel" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="MetaLabel" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
            <!-- Что реально лежит рядом с версией (LFS/PSL/HMI/параметры/документы). Раньше это было
                 видно только по тому, есть ли пункт в меню «Ещё» — то есть «есть ли LFS» приходилось
                 выяснять, открыв меню и не найдя там строки. -->
            <TextBlock x:Name="FilesLabel" Style="{StaticResource MutedText}" Margin="0,2,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="DescLabel" Style="{StaticResource SubtitleText}" TextWrapping="Wrap" Margin="0,4,0,0"
                       MouseLeftButtonUp="DescLabel_Click"/>
            <views:TagBubbleEditor x:Name="TagsView" Margin="0,4,0,0"/>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="SoftwareNameLabel" VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="CopyButton" Content="Копировать" Style="{StaticResource SecondaryButton}" Click="Copy_Click"/>
            </Grid>

            <!-- Состояние локальной копии: раньше на её месте была кнопка «Синхронизировать»,
                 теперь копия подтягивается сама (SearchView.AutoSyncMissing), а карточка просто
                 показывает, что с ней происходит. Ручная синхронизация осталась в меню «Ещё». -->
            <TextBlock x:Name="SyncStatusLabel" Style="{StaticResource MutedText}" Margin="0,6,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <WrapPanel x:Name="ActionsPanel" Margin="0,8,0,0"/>

            <Popup x:Name="MorePopup" StaysOpen="False" AllowsTransparency="True"
                   Placement="Bottom" HorizontalOffset="0" VerticalOffset="2">
                <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1" CornerRadius="6" Padding="6">
                    <StackPanel x:Name="MorePanel" MinWidth="230"/>
                </Border>
            </Popup>
        </StackPanel>
    </Border>
</UserControl>
