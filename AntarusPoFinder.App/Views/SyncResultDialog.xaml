<Window x:Class="AntarusPoFinder.App.Views.SyncResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Синхронизация" Width="420" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Прошивка синхронизирована на локальный ПК" FontWeight="Bold"
                   Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>
        <TextBlock x:Name="InfoText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Открыть прошивку" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenFirmware_Click"/>
            <Button Content="Открыть папку" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenFolder_Click"/>
            <Button Content="Закрыть" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
