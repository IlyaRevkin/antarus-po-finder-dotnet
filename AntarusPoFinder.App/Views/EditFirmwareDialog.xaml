<Window x:Class="AntarusPoFinder.App.Views.EditFirmwareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AntarusPoFinder.App.Views"
        Icon="/Assets/icon.ico"
        Width="520" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="TitleLabel" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <TextBlock Text="Описание:" Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionInput" Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

        <TextBlock Text="Теги:" Margin="0,0,0,4"/>
        <views:TagBubbleEditor x:Name="TagsEditor" Margin="0,0,0,12"/>

        <TextBlock Text="Тип пуска:" Margin="0,0,0,4"/>
        <!-- WrapPanel, не горизонтальный StackPanel: пятый тип пуска («Отсутствует», см.
             ConfigService.LaunchTypes) не помещается в 520px ширины окна одной строкой и у
             StackPanel просто обрезался бы без возможности до него добраться. -->
        <WrapPanel x:Name="LaunchTypesPanel" Orientation="Horizontal" Margin="0,0,0,16"/>

        <!-- Модерация исполняемых файлов: и для ПЛК, и для HMI (раньше можно было переназначить
             только HMI, и только среди файлов КОРНЯ папки — если нужный файл лежал во вложенной
             папке, выбрать его было нечем). Кнопка открывает PickFileDialog с обходом подпапок. -->
        <StackPanel x:Name="ExecutablesPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <TextBlock Text="ИСПОЛНЯЕМЫЕ ФАЙЛЫ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>

            <Grid x:Name="PlcExecutableRow" Margin="0,0,0,6" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Прошивка ПЛК:" VerticalAlignment="Center"
                           ToolTip="Какой файл в папке версии открывать по кнопке «Открыть прошивку ПЛК»."/>
                <TextBlock Grid.Column="1" x:Name="PlcExecutableText" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Выбрать..." Style="{StaticResource SecondaryButton}" Click="PickPlcExecutable_Click"/>
            </Grid>

            <Grid x:Name="HmiExecutableRow" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="HMI-проект:" VerticalAlignment="Center"
                           ToolTip="Какой файл в папке HMI-проекта открывать по кнопке «Открыть HMI проект»."/>
                <TextBlock Grid.Column="1" x:Name="HmiExecutableText" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Выбрать..." Style="{StaticResource SecondaryButton}" Click="PickHmiExecutable_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="90" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
