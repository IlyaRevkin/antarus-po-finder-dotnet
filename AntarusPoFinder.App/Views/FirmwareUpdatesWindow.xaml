<Window x:Class="AntarusPoFinder.App.Views.FirmwareUpdatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Обновления прошивок" Width="680" Height="560" MinWidth="520" MinHeight="360"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="UpdateAllButton" Content="Обновить все" Margin="0,0,8,0" Click="UpdateAll_Click"/>
            <Button x:Name="UpdateSelectedButton" Content="Обновить выделенные" Style="{StaticResource SecondaryButton}" Click="UpdateSelected_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ItemsPanel"/>
        </ScrollViewer>

        <!-- Своя строка прогресса, а не общая внизу главного окна: это окно модальное, статус-строка
             под ним не видна, а копирование прошивки с сетевого диска идёт секундами-минутами. -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="ProgressPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="Collapsed">
                <ProgressBar x:Name="ProgressIndicator" Width="120" Height="6" VerticalAlignment="Center" Maximum="100"/>
                <TextBlock x:Name="ProgressText" Style="{StaticResource MutedText}" Margin="8,0,12,0"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Закрыть" IsCancel="True" Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" Width="100" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
