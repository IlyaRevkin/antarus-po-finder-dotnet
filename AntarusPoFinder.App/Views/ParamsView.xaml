<UserControl x:Class="AntarusPoFinder.App.Views.ParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Параметры ПЧ / УПП" Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Upload section -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="ЗАГРУЗИТЬ ПАРАМЕТРЫ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип шкафа:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <ComboBox x:Name="GroupCombo" Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,8"
                                  DisplayMemberPath="Name" SelectionChanged="GroupCombo_SelectionChanged"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Подтип:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <ComboBox x:Name="SubCombo" Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,8"
                                  DisplayMemberPath="Label"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Производитель:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <ComboBox x:Name="ManufCombo" Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Файл:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Выбрать файл…" Style="{StaticResource SecondaryButton}" Height="34" Click="BrowseFile_Click"/>
                            <TextBlock x:Name="FileLabel" Text="Файл не выбран" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        </DockPanel>

                        <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource DropZoneBorder}" Height="52" Margin="0,0,0,8"
                                AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver">
                            <TextBlock x:Name="DropZoneLabel" Text="Перетащите файл сюда" Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Описание:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="DescInput" Grid.Row="5" Grid.Column="1" Height="36"
                                 ToolTip="Краткое описание (необязательно)"/>
                    </Grid>
                    <Button Content="Загрузить параметры" HorizontalAlignment="Right" Height="38" Margin="0,12,0,0" Click="Upload_Click"/>
                </StackPanel>
            </Border>

            <!-- List section -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ЗАГРУЖЕННЫЕ ПАРАМЕТРЫ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- The table (and its "Удалить запись" button) only appears after this is
                         clicked — showing it immediately on tab open made an accidental click too
                         easy to land on the wrong row and delete it. -->
                    <Button Grid.Row="1" x:Name="ShowAllButton" Content="Все загруженные" HorizontalAlignment="Left"
                            Margin="0,0,0,10" Click="ShowAllButton_Click"/>

                    <Grid Grid.Row="2" x:Name="ListContentPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FilterGroupCombo" Width="150" Margin="0,0,16,0" DisplayMemberPath="Name" SelectionChanged="Filter_Changed"/>
                            <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FilterManufCombo" Width="150" Margin="0,0,16,0" SelectionChanged="Filter_Changed"/>
                            <Button Content="Обновить" Style="{StaticResource SecondaryButton}" Click="Refresh_Click"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" x:Name="FilesGrid" SelectionMode="Single" SelectionUnit="FullRow"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Файл" Binding="{Binding Filename}" Width="*"/>
                                <DataGridTextColumn Header="Группа / Подтип" Binding="{Binding GroupSubtypeDisplay}" Width="160"/>
                                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="120"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding DateOnly}" Width="100"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="180"/>
                                <DataGridTextColumn Header="Теги" Binding="{Binding TagsDisplay}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Открыть папку" Style="{StaticResource SecondaryButton}" Height="34" Click="OpenFolder_Click"/>
                            <Button Content="Теги" Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0" Click="EditTags_Click"/>
                            <Button Content="Удалить запись" Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0" Click="DeleteRow_Click"/>
                            <TextBlock x:Name="CountLabel" Text="Записей: 0" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
