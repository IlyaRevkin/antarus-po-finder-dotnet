<UserControl x:Class="AntarusPoFinder.App.Views.ParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntarusPoFinder.App.Views">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Параметры ПЧ / УПП" Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

        <!-- Whole page scrolls — the previous fix (capping the upload card's height) still left the
             list card fighting the upload card for whatever was left of a non-maximized window, down
             to 0 visible rows on the default 1280x800 size. A page-level scrollbar means the table is
             always reachable regardless of window size, and the list card below gets a fixed, always-
             adequate height instead of a shrinkable "*" share. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Upload section — sizes to its own content (no fixed height / inner scrollbar): capping
                 it used to force a cramped nested scrollbar inside a small card even though the page
                 itself already scrolls (see the ScrollViewer wrapping this whole Grid) - two scrollbars
                 fighting for the same handful of fields read as broken, not compact. Тип шкафа/Подтип
                 paired on one row (same shape, same reasoning as UploadView's "Карта in/out" + "Карта
                 modbus" pairing) trims a full row of height instead. -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="ЗАГРУЗИТЬ ПАРАМЕТРЫ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <!-- Тип шкафа/Подтип/Производитель side by side, one row — all three are short
                         values (2-3 words at most), so stretching each across the whole card on its
                         own row (as Тип+Подтип already were, with Производитель a full row further
                         down) wasted height for what they hold. Same "*" trailing column reasoning as
                         UploadView's combo row. Widths (150/130/170) match UploadView's own Тип/
                         Подтип/Контроллер row exactly — this is conceptually the same row (Round 43:
                         these were 180/180/180 here, visibly wider/chunkier than every other combo
                         row in the app for values that are just as short — "oversized relative to the
                         rest of the UI" per the user's report). -->
                    <!-- Same star+MinWidth/MaxWidth sizing as UploadView's copy of this row (see there
                         for why: a fixed pixel Width can't shrink and overflows the window in narrower
                         layouts). This page has the full width to itself so it wasn't observed to overflow
                         here, but keeping both rows on the same resilient pattern — not just the same
                         pixel numbers — is the point, since they're explicitly kept in sync. -->
                    <!-- Первая колонка — 110, как и у всех строк ниже («Ещё подтипы:»/«Файл:»/«Описание:»),
                         а не Auto: левый край GroupCombo должен начинаться там же, где начинаются
                         поля ниже. С Auto ширина подписи «Тип шкафа:» подгонялась под текст и левый
                         край комбобоксов уезжал левее/правее полей ниже — комбобоксы и поля визуально
                         не выравнивались по x. -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="150*" MinWidth="70" MaxWidth="150"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="130*" MinWidth="60" MaxWidth="130"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="170*" MinWidth="70" MaxWidth="170"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Тип шкафа:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="GroupCombo" Grid.Column="1" Height="34"
                                  DisplayMemberPath="Name" SelectionChanged="GroupCombo_SelectionChanged"/>
                        <TextBlock Grid.Column="3" Text="Подтип:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="SubCombo" Grid.Column="4" Height="34" DisplayMemberPath="Label"
                                  SelectionChanged="SubCombo_SelectionChanged"/>
                        <TextBlock Grid.Column="6" Text="Производитель:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ManufCombo" Grid.Column="7" Height="34"/>
                    </Grid>

                    <!-- Один и тот же файл параметров часто подходит нескольким подтипам шкафа.
                         Основной подтип (комбобокс выше) определяет папку, куда файл реально
                         копируется; здесь выбираются ДОПОЛНИТЕЛЬНЫЕ — им заводится своя запись, а в
                         их папку кладётся ярлык на тот же файл, без дублирования на диске. Та же
                         пара «подпись слева 110 + содержимое», что у строк «Файл:»/«Описание:» ниже —
                         иначе ряд визуально выпадал бы из карточки. Сам выбор — чекбоксы прямо в
                         выпадающем списке (SubtypeMultiSelect), без отдельного модального окна. -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ещё подтипы:" VerticalAlignment="Center" Margin="0,0,8,0"
                                   ToolTip="Подтипы шкафов, которым подходит этот же файл параметров — файл не дублируется, в их папки кладётся ярлык."/>
                        <views:SubtypeMultiSelect Grid.Column="1" x:Name="ExtraSubtypesSelect" Height="34"/>
                    </Grid>

                    <!-- Кнопка выбора файла и drag&amp;drop-зона merged into one row instead of two
                         separate-looking rows stacked on top of each other — the drop zone itself now
                         also shows the picked filename (DropZoneLabel doubles as what FileLabel used
                         to be, they were always kept in sync anyway, see SetFile). -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Файл:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Grid.Column="1" Style="{StaticResource DropZoneBorder}" Height="46" Margin="0,0,8,0"
                                AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver">
                            <TextBlock x:Name="DropZoneLabel" Text="Перетащите файл сюда, или нажмите «Выбрать файл…»" Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="2" Content="Выбрать файл…" Style="{StaticResource CompactSecondaryButton}" VerticalAlignment="Center" Click="BrowseFile_Click"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Описание:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="DescInput" Grid.Column="1" Height="34"
                                 ToolTip="Краткое описание (необязательно)"/>
                    </Grid>

                    <Button x:Name="UploadBtn" Content="Загрузить параметры" HorizontalAlignment="Right" Height="36" Margin="0,10,0,0" Click="Upload_Click"/>
                </StackPanel>
            </Border>

            <!-- List section — fixed height (own internal scrollbar via the DataGrid, same pattern
                 as the upload card above) instead of a "*" share of whatever the page grid had left,
                 so the table always shows several rows without needing to maximize the window. -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ЗАГРУЖЕННЫЕ ПАРАМЕТРЫ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Свернуть/Развернуть + the row actions live together in one header row (same
                         physical position regardless of expand state — moved here from below the table
                         so they're not hunted for at the bottom of a possibly-tall grid), but
                         "Открыть папку"/"Теги"/"Удалить запись" only make sense once there's a visible,
                         selectable row to act on: collapsed by default together with the table itself,
                         shown again the moment "Все загруженные" expands it (ShowAllButton_Click).
                         CountLabel stays visible either way — the count itself doesn't need the table
                         open to be meaningful. -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="ShowAllButton" Content="Все загруженные" Click="ShowAllButton_Click"/>
                        <Button x:Name="OpenFolderBtn" Content="Открыть папку" Style="{StaticResource CompactSecondaryButton}" Margin="8,0,0,0" Click="OpenFolder_Click" Visibility="Collapsed"/>
                        <Button x:Name="EditTagsBtn" Content="Теги" Style="{StaticResource CompactSecondaryButton}" Margin="8,0,0,0" Click="EditTags_Click" Visibility="Collapsed"/>
                        <Button x:Name="DeleteRowBtn" Content="Удалить запись" Style="{StaticResource CompactSecondaryButton}" Margin="8,0,0,0" Click="DeleteRow_Click" Visibility="Collapsed"/>
                        <TextBlock x:Name="CountLabel" Text="Записей: 0" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2" x:Name="ListContentPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FilterGroupCombo" Width="150" Margin="0,0,16,0" DisplayMemberPath="Name" SelectionChanged="Filter_Changed"/>
                            <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FilterManufCombo" Width="150" Margin="0,0,16,0" SelectionChanged="Filter_Changed"/>
                            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchInput" Width="180" Margin="0,0,16,0" VerticalContentAlignment="Center"
                                     ToolTip="Файл / описание / теги" TextChanged="Filter_Changed"/>
                            <Button Content="Обновить" Style="{StaticResource SecondaryButton}" Click="Refresh_Click"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" x:Name="FilesGrid" SelectionMode="Single" SelectionUnit="FullRow"
                                  Height="320" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Файл" Binding="{Binding Filename}" Width="*"/>
                                <DataGridTextColumn Header="Группа / Подтип" Binding="{Binding GroupSubtypeDisplay}" Width="160"/>
                                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="120"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding DateOnly}" Width="100"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="180"/>
                                <DataGridTextColumn Header="Теги" Binding="{Binding TagsDisplay}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
