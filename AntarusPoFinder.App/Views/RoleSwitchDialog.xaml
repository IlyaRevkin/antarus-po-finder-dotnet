<Window x:Class="AntarusPoFinder.App.Views.RoleSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Сменить роль" Width="360" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Роль:" Margin="0,0,0,4"/>
        <ComboBox x:Name="RoleCombo" Margin="0,0,0,12" DisplayMemberPath="Label" SelectedValuePath="RoleId"/>
        <TextBlock Text="Пароль (если требуется):" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordInput" Margin="0,0,0,16"/>
        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Сменить" Width="90" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>

        <Separator Margin="0,0,0,12"/>
        <TextBlock Text="ИЛИ ВОЙТИ ПО ЛОГИНУ И ПАРОЛЮ AD" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Text="Домен:" Margin="0,0,0,4"/>
        <TextBox x:Name="AdDomainInput" Margin="0,0,0,10"/>
        <TextBlock Text="Логин:" Margin="0,0,0,4"/>
        <TextBox x:Name="AdLoginInput" Margin="0,0,0,10" ToolTip="Например: revkin.i"/>
        <TextBlock Text="Пароль AD:" Margin="0,0,0,4"/>
        <PasswordBox x:Name="AdPasswordInput" Margin="0,0,0,12"/>
        <Button x:Name="AdAuthBtn" Content="Войти по AD" HorizontalAlignment="Right" Click="AdAuth_Click"
                ToolTip="Проверяет логин/пароль в домене и определяет роль по членству в настроенных AD-группах (Настройки → Общие)."/>
    </StackPanel>
</Window>
