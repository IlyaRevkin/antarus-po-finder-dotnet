<Window x:Class="AntarusPoFinder.App.Views.AuthoritativeDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Эталонная синхронизация — предпросмотр" Width="720" Height="640" MinWidth="560" MinHeight="360"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Что изменится у остальных компьютеров" Style="{StaticResource TitleText}" Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedText}"
                       Text="Сравнение справочника этой машины с тем, что сейчас лежит в общем конфиге на диске. Зелёным — появится там, где этого ещё нет; красным — удалится там, где это ещё есть (кроме записей, которые получатель ещё использует в своих прошивках или файлах параметров — они будут автоматически пропущены). Сами прошивки, файлы параметров, резервы номеров и пользователи не затрагиваются — только восемь категорий справочника ниже."/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="CategoriesPanel"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="NoChangesText" Text="Изменений относительно диска нет." Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed"/>
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Width="110" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="ConfirmButton" Content="Подтвердить и отправить" Style="{StaticResource DangerButton}" Width="200" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
