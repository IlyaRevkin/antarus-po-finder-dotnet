<Window x:Class="AntarusPoFinder.App.Views.UnknownFilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Width="700" Height="460" MinWidth="700" MinHeight="460"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✓ Отмеченные → перенести в «Неизвестное».  ✗ Снятые отметки → удалить безвозвратно."
                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Выбрать все" Style="{StaticResource SecondaryButton}" Click="CheckAll_Click" Margin="0,0,8,0"/>
            <Button Content="Снять все" Style="{StaticResource SecondaryButton}" Click="UncheckAll_Click"/>
        </StackPanel>

        <ListBox Grid.Row="2" x:Name="ItemsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Display}" IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,8,0" Click="Close_Click"/>
            <Button Content="Применить (перенести ✓ / удалить ✗)" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
