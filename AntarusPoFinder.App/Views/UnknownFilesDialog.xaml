<Window x:Class="AntarusPoFinder.App.Views.UnknownFilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Width="760" Height="520" MinWidth="760" MinHeight="460"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                    Text="Отметьте элементы галочкой, затем выберите действие: перенести в «Неизвестное» (спрятать с диска, ничего не удаляя), переместить в существующую группу/подтип/контроллер (или производителя), либо удалить безвозвратно."
                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Выбрать все" Style="{StaticResource SecondaryButton}" Click="CheckAll_Click" Margin="0,0,8,0"/>
            <Button Content="Снять все" Style="{StaticResource SecondaryButton}" Click="UncheckAll_Click"/>
        </StackPanel>

        <ListBox Grid.Row="2" x:Name="ItemsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Display}" IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Click="Close_Click"/>
            <Button Content="Удалить выбранные" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="DeleteSelected_Click"/>
            <Button Content="В «Неизвестное»" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="MoveToUnknownSelected_Click"/>
            <Button Content="Переместить в…" Click="ReassignSelected_Click"/>
        </StackPanel>
    </Grid>
</Window>
