<UserControl x:Class="AntarusPoFinder.App.Views.TicketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Тикеты" Style="{StaticResource TitleText}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="ScopeHintText" Text="Баг-репорты и предложения по программе."
                   Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <!-- New ticket -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="НОВЫЙ ТИКЕТ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="TicketTypeCombo" Height="34" Margin="0,0,8,0" DisplayMemberPath="Label"/>
                    <TextBox Grid.Column="1" x:Name="TicketTextInput" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                              VerticalScrollBarVisibility="Auto"
                              ToolTip="Опишите проблему или предложение — что произошло/что хотелось бы, по возможности как воспроизвести."/>
                </Grid>
                <Button Content="Создать тикет" HorizontalAlignment="Left" Click="CreateTicket_Click"/>
            </StackPanel>
        </Border>

        <!-- List -->
        <DataGrid Grid.Row="3" x:Name="TicketsGrid" AutoGenerateColumns="False" Margin="0,0,0,10"
                  IsReadOnly="True" SelectionChanged="TicketsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeLabel}" Width="90"/>
                <DataGridTextColumn Header="Текст" Binding="{Binding Text}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusLabel}" Width="90"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding CreatedBy}" Width="120"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding CreatedByRoleLabel}" Width="110"/>
                <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAtLabel}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button Content="Обновить" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button x:Name="TakeInProgressBtn" Content="Взять в работу" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    Click="SetStatus_Click" Tag="in_progress" Visibility="Collapsed"/>
            <Button x:Name="CloseTicketBtn" Content="Закрыть" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    Click="SetStatus_Click" Tag="closed" Visibility="Collapsed"/>
            <Button x:Name="ReopenTicketBtn" Content="Переоткрыть" Style="{StaticResource SecondaryButton}"
                    Click="SetStatus_Click" Tag="open" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</UserControl>
