<Window x:Class="AntarusPoFinder.App.Views.LoaderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Загрузка через лоадер" Width="760" Height="640" MinWidth="620" MinHeight="520"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="HeaderLabel" Style="{StaticResource TitleText}" TextWrapping="Wrap"/>
            <TextBlock x:Name="BackendLabel" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Пока подключена заготовка, а не настоящий лоадер, это должно быть видно сразу и всё
             время — иначе пройденный «успешно» прогресс-бар легко принять за реальную загрузку. -->
        <Border Grid.Row="1" x:Name="StubBanner" Style="{StaticResource CardBorder}" Margin="0,0,0,10"
                BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Реальная загрузка не выполняется — это заготовка"
                           FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap"/>
                <TextBlock x:Name="StubReasonLabel" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Параметры запуска -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="ПАРАМЕТРЫ ЗАГРУЗКИ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Файл:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="SourceInput" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="BrowseSourceBtn" Content="Обзор…" Style="{StaticResource SecondaryButton}" Click="BrowseSource_Click"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Порт/адрес:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TargetInput" Height="32" VerticalContentAlignment="Center"
                             ToolTip="COM-порт или IP-адрес контроллера — формат задаёт сам лоадер"/>
                </Grid>

                <WrapPanel Orientation="Horizontal">
                    <CheckBox x:Name="FormatCheck" Content="Форматировать память контроллера" Margin="0,0,20,4"
                              ToolTip="Стирает пользовательские данные в контроллере перед загрузкой"/>
                    <CheckBox x:Name="UpdateKernelCheck" Content="Обновить ядро контроллера" Margin="0,0,0,4"
                              ToolTip="Обновляет системное ПО контроллера, если версия не совпадает с требуемой"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Прогресс -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <ProgressBar x:Name="Progress" Height="16" Minimum="0" Maximum="100" Value="0"
                             Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource BgInputBrush}"
                             BorderBrush="{DynamicResource BorderBrush2}"/>
                <TextBlock x:Name="StageLabel" Style="{StaticResource MutedText}" Margin="0,4,0,0" Text="Готов к запуску"/>
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="PercentLabel" VerticalAlignment="Center" Margin="10,0,0,0" Text=""/>
        </Grid>

        <!-- Лог -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ЛОГ ЗАГРУЗКИ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LogPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OpenWorkspaceBtn" Content="Рабочая папка" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    IsEnabled="False" Click="OpenWorkspace_Click"
                    ToolTip="Локальная папка этого запуска: исходники, результат, лог"/>
            <Button x:Name="SaveLogBtn" Content="Сохранить лог…" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    IsEnabled="False" Click="SaveLog_Click"/>
            <Button x:Name="StopBtn" Content="Остановить" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    IsEnabled="False" Click="Stop_Click"/>
            <Button x:Name="RunBtn" Content="Запустить" Margin="0,0,8,0" Click="Run_Click"/>
            <Button Content="Закрыть" Style="{StaticResource SecondaryButton}" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
