<Window x:Class="AntarusPoFinder.App.Views.AddModificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Добавить модификацию"
        Width="380" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Модификация:" Margin="0,0,0,4"/>
        <TextBox x:Name="NameInput" Margin="0,0,0,12" ToolTip="напр. PIXEL2-1020"/>

        <TextBlock Text="hw_version:" Margin="0,0,0,4"/>
        <TextBox x:Name="HwVersionInput" Margin="0,0,0,12" ToolTip="целое число, напр. 41"/>

        <TextBlock Text="Описание:" Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionInput" Margin="0,0,0,16" ToolTip="напр. 8DI / 6DO / 8AI / 2AO"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Добавить" Width="90" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
