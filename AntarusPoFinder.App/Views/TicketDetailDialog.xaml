<Window x:Class="AntarusPoFinder.App.Views.TicketDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/icon.ico"
        Title="Тикет" Width="580" Height="560" MinWidth="420" MinHeight="360"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderText" Style="{StaticResource TitleText}" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <TextBlock x:Name="MetaText" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Full text, wrapped and scrollable — the grid row itself only shows a trimmed single
             line (see TicketsView.xaml), this is where the whole thing is actually readable. -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="BodyText" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="2" Text="ВЛОЖЕНИЯ" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <TextBlock x:Name="NoAttachmentsText" Text="Нет вложений" Style="{StaticResource MutedText}"
                       HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <ListBox x:Name="AttachmentsList" Visibility="Collapsed" MouseDoubleClick="AttachmentsList_MouseDoubleClick"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Открыть файл" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenAttachment_Click"/>
            <Button Content="Открыть папку вложений" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenAttachmentsFolder_Click"/>
            <Button Content="Закрыть" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
